@model VelvySkinWeb.Models.Order
@{
    ViewData["Title"] = "Hoàn tất #" + Model.Id;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 26px; color: var(--dark-mint); margin: 0; }
    
    .back-btn { text-decoration: none; color: #888; font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; margin-bottom: 20px; transition: 0.3s;}
    .back-btn:hover { color: var(--primary-mint); }

    /* Badge trạng thái Đã giao */
    .status-completed { background: var(--light-mint); color: var(--primary-mint); padding: 8px 20px; border-radius: 30px; font-size: 12px; font-weight: 700; display: flex; align-items: center; gap: 8px; border: 1px solid var(--primary-mint); }

    .grid-layout { display: grid; grid-template-columns: 1.5fr 1fr; gap: 25px; }

    .card { background: white; border-radius: 25px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); margin-bottom: 25px; border: 1px solid #f1f1f1; }
    .card-title { font-weight: 700; font-size: 14px; text-transform: uppercase; color: var(--dark-mint); margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }

    /* Nhật ký hành trình tĩnh cho đơn đã xong */
    .timeline { position: relative; padding-left: 30px; margin-top: 20px; }
    .timeline::before { content: ''; position: absolute; left: 7px; top: 5px; width: 2px; height: 85%; background: #eee; }
    .timeline-item { position: relative; margin-bottom: 25px; }
    .timeline-dot { position: absolute; left: -30px; top: 4px; width: 16px; height: 16px; border-radius: 50%; background: #ddd; border: 3px solid white; z-index: 2; }
    .timeline-dot.completed { background: var(--primary-mint); }
    .timeline-info { font-size: 13px; }
    .timeline-time { font-size: 11px; color: #aaa; font-weight: 600; }
    .timeline-content { font-weight: 600; margin-top: 3px; }

    /* Danh sách sản phẩm thu nhỏ */
    .product-mini { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; font-size: 13px; border-bottom: 1px solid #fafafa; padding-bottom: 8px;}
    .product-mini img { width: 40px; height: 40px; border-radius: 8px; object-fit: cover; border: 1px solid #eee;}

    .info-row { display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 13px; }
    .info-label { color: #888; }
    .info-value { font-weight: 600; }

    .total-box { border-top: 1px dashed #eee; margin-top: 15px; padding-top: 15px; }

    /* Nút phụ trợ */
    .btn-secondary { background: #f8f9fa; color: #555; border: 1px solid #eee; padding: 12px; border-radius: 12px; cursor: pointer; font-weight: 600; width: 100%; margin-top: 10px; display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.3s;}
    .btn-secondary:hover { background: #eee;}

    @@media (max-width: 800px) { .grid-layout { grid-template-columns: 1fr; } }
</style>

<a asp-controller="Admin" asp-action="Orders" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Quay lại danh sách đơn hàng</a>

<div class="order-header">
    <div>
        <h1 class="page-title">Đơn hàng #@Model.Id</h1>
        <p style="font-size: 13px; color: #888; margin-top: 5px;">Mã vận đơn: <strong style="color: #333;">GHTK-55201192</strong></p>
    </div>
    <div class="status-completed">
        <i class="fa-solid fa-circle-check"></i> ĐÃ GIAO THÀNH CÔNG
    </div>
</div>

<div class="grid-layout">
    <div class="left-col">
        <div class="card">
            <div class="card-title"><i class="fa-solid fa-clock-rotate-left"></i> Nhật ký hành trình</div>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-dot completed"></div>
                    <div class="timeline-info">
                        <div class="timeline-time">@Model.OrderDate.AddDays(2).ToString("dd/MM/yyyy, hh:mm tt")</div>
                        <div class="timeline-content" style="color: #27ae60;">Đã nhận hàng & Thanh toán thành công</div>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-info">
                        <div class="timeline-time">@Model.OrderDate.AddDays(1).ToString("dd/MM/yyyy, hh:mm tt")</div>
                        <div class="timeline-content">Đơn hàng bắt đầu được giao</div>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-info">
                        <div class="timeline-time">@Model.OrderDate.AddHours(2).ToString("dd/MM/yyyy, hh:mm tt")</div>
                        <div class="timeline-content">Đã xác nhận và đóng gói tại Shop</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-title"><i class="fa-solid fa-box-open"></i> Kiện hàng đã nhận (@(Model.OrderDetails?.Count ?? 0))</div>
            @if(Model.OrderDetails != null)
            {
                foreach(var item in Model.OrderDetails)
                {
                    <div class="product-mini">
                        <img src="@(item.Product?.ImageUrl ?? "https://via.placeholder.com/40")" alt="sp">
                        <div style="flex:1"><strong>@(item.Product?.Name ?? "Sản phẩm")</strong></div>
                        <div style="font-weight: 700; color: var(--primary-mint);">x@(item.Quantity)</div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="right-col">
        <div class="card">
            <div class="card-title"><i class="fa-solid fa-address-card"></i> Thông tin khách hàng</div>
            <div class="info-row">
                <span class="info-label">Khách hàng:</span>
                <span class="info-value">@Model.CustomerName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Số điện thoại:</span>
                <span class="info-value">@Model.PhoneNumber</span>
            </div>
           <div class="info-row" style="align-items: flex-start;">
                <span class="info-label" style="white-space: nowrap; margin-right: 15px;">Địa chỉ giao:</span>
                <span class="info-value" style="text-align: right; line-height: 1.5;">@Model.ShippingAddress</span>
            </div>
        </div>

        <div class="card">
            <div class="card-title"><i class="fa-solid fa-file-invoice-dollar"></i> Tổng kết thanh toán</div>
            <div class="info-row">
                <span class="info-label">Tiền hàng:</span>
                <span class="info-value">@Model.TotalAmount.ToString("N0")đ</span>
            </div>
            <div class="info-row">
                <span class="info-label">Phương thức:</span>
                <span class="info-value">@(Model.PaymentMethod ?? "COD")</span>
            </div>
            <div class="total-box">
                <div class="info-row" style="font-size: 18px; margin-top: 10px;">
                    <span style="font-weight: 700; color: var(--dark-mint);">Đã thu:</span>
                    <span style="font-weight: 700; color: var(--primary-mint);">@Model.TotalAmount.ToString("N0")đ</span>
                </div>
            </div>
            <button class="btn-secondary" onclick="window.print()">
                <i class="fa-solid fa-print"></i> In lại hóa đơn
            </button>
        </div>
    </div>
</div>