@model VelvySkinWeb.Models.Order
@{ ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id; }

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 style="color: var(--primary-mint); font-family: 'Playfair Display';">CHI TIẾT ĐƠN HÀNG #@Model.Id</h2>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left"></i> Quay lại danh sách</a>
    </div>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm">@TempData["SuccessMsg"]</div>
    }

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-dark text-white fw-bold">Thông tin giao hàng</div>
                <div class="card-body">
                    <p><strong>Người nhận:</strong> @Model.CustomerName</p>
                    <p><strong>Điện thoại:</strong> @Model.PhoneNumber</p>
                    <p><strong>Địa chỉ:</strong> @Model.ShippingAddress</p>
                    <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    
                    <hr />
                    <h5 class="fw-bold">Trạng thái hiện tại: 
                        <span class="text-danger">@Model.OrderStatus</span>
                    </h5>

                    <form asp-action="UpdateStatus" method="post" class="mt-3">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <label class="fw-bold mb-2">Đổi trạng thái thành:</label>
                        <select name="newStatus" class="form-select mb-3">
                            <option value="Pending" selected="@(Model.OrderStatus == "Pending")">Chờ xử lý (Pending)</option>
                            <option value="Shipping" selected="@(Model.OrderStatus == "Shipping")">Đang giao hàng (Shipping)</option>
                            <option value="Completed" selected="@(Model.OrderStatus == "Completed")">Hoàn thành (Completed)</option>
                            <option value="Cancelled" selected="@(Model.OrderStatus == "Cancelled")">Hủy đơn (Cancelled)</option>
                        </select>
                        <button type="submit" class="btn w-100 fw-bold" style="background-color: var(--primary-mint); color: white;">CẬP NHẬT TRẠNG THÁI</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold">Danh sách sản phẩm xuất kho</div>
                <div class="card-body p-0">
                    <table class="table table-borderless align-middle mb-0">
                        <thead class="table-light border-bottom">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end pe-4">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(Model.OrderDetails != null)
                            {
                                @foreach (var detail in Model.OrderDetails)
                                {
                                    <tr class="border-bottom">
                                        <td>
                                            <img src="@detail.Product?.ImageUrl" alt="img" style="width: 40px; height:40px; object-fit: cover; border-radius: 4px; margin-right: 10px;" />
                                            @detail.Product?.Name
                                        </td>
                                        <td class="text-center text-muted">@detail.UnitPrice.ToString("N0") đ</td>
                                        <td class="text-center fw-bold">x @detail.Quantity</td>
                                        <td class="text-end fw-bold text-danger pe-4">@((detail.UnitPrice * detail.Quantity).ToString("N0")) đ</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white text-end py-3 pe-4">
                    <h4 class="fw-bold mb-0">TỔNG CỘNG: <span class="text-danger">@Model.TotalAmount.ToString("N0") đ</span></h4>
                </div>
            </div>
        </div>
    </div>
</div>