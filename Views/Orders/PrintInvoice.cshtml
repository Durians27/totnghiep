@model VelvySkinWeb.Models.Order
@{
    Layout = null; 
    
    decimal subTotal = Model.OrderDetails.Sum(od => od.UnitPrice * od.Quantity);
    decimal shippingFee = (subTotal > 0 && subTotal < 500000) ? 30000 : 0;
    decimal discount = (subTotal + shippingFee) - Model.TotalAmount;

    // BỘ DỊCH TRẠNG THÁI SANG TIẾNG VIỆT
    string statusVN = Model.OrderStatus switch {
        "Pending" => "Chờ xác nhận",
        "Shipping" => "Đang giao hàng",
        "Completed" => "Đã giao thành công",
        "Cancelled" => "Đã hủy",
        _ => Model.OrderStatus
    };

    // CHỌN MÀU CHO TRẠNG THÁI
    string statusBg = Model.OrderStatus == "Pending" ? "#fff3cd" : (Model.OrderStatus == "Cancelled" ? "#f8d7da" : "#e6fcf5");
    string statusColor = Model.OrderStatus == "Pending" ? "#856404" : (Model.OrderStatus == "Cancelled" ? "#721c24" : "#208b81");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hóa Đơn #@Model.Id | Velvy Skin</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --primary-mint: #2ec4b6; --dark-mint: #208b81; --gold: #c5a059;
            --text-main: #333; --bg-invoice: #ffffff;
        }
        body { font-family: 'Montserrat', sans-serif; background: #f0f2f5; margin: 0; padding: 40px 20px; color: var(--text-main); }
        .invoice-wrapper { max-width: 850px; margin: 0 auto; background: var(--bg-invoice); padding: 60px; border-radius: 2px; box-shadow: 0 0 20px rgba(0,0,0,0.05); position: relative; }
        .invoice-wrapper::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 8px; background: linear-gradient(90deg, var(--primary-mint), var(--gold)); }

        .invoice-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 50px; border-bottom: 1px solid #eee; padding-bottom: 30px; }
        
        /* ĐÃ CHỈNH LOGO TO LÊN VÀ CĂN SÁT TRÁI */
        .brand-section { display: flex; flex-direction: column; align-items: flex-start; gap: 15px; }
        .brand-logo { max-width: 160px; height: auto; object-fit: contain; margin-left: -10px; } 
        
        .brand-info p { font-size: 13px; color: #777; margin: 5px 0; line-height: 1.6; }

        .invoice-status { text-align: right; }
        .status-badge { display: inline-block; padding: 8px 15px; background: @statusBg; color: @statusColor; font-weight: 700; font-size: 12px; text-transform: uppercase; border-radius: 5px; margin-bottom: 10px; }
        .invoice-meta { font-size: 14px; color: #555; }

        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 40px; padding: 30px; background: #fcfcfc; border-radius: 10px; }
        .info-block h4 { font-size: 11px; text-transform: uppercase; color: var(--gold); margin-bottom: 15px; letter-spacing: 1px; }
        .info-block p { font-size: 14px; margin: 5px 0; font-weight: 500; }

        .invoice-table { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
        .invoice-table th { text-align: left; padding: 15px; border-bottom: 2px solid var(--primary-mint); font-size: 12px; text-transform: uppercase; color: #888; }
        .invoice-table td { padding: 20px 15px; border-bottom: 1px solid #eee; font-size: 14px; }
        .item-name { font-weight: 600; color: #222; }

        .invoice-summary { display: flex; justify-content: flex-end; }
        .summary-box { width: 300px; }
        .summary-row { display: flex; justify-content: space-between; padding: 10px 0; font-size: 14px; }
        .summary-row.total { border-top: 2px solid #eee; margin-top: 10px; padding-top: 20px; font-weight: 700; font-size: 18px; color: var(--dark-mint); }

        .invoice-footer { margin-top: 60px; text-align: center; border-top: 1px solid #eee; padding-top: 30px; }
        .thanks-msg { font-family: 'Playfair Display'; font-size: 18px; color: var(--gold); margin-bottom: 10px; }
        
        .action-btns { margin-top: 30px; display: flex; justify-content: center; gap: 15px; }
        .btn { padding: 12px 25px; border-radius: 30px; font-weight: 600; font-size: 13px; cursor: pointer; border: none; transition: 0.3s; text-decoration: none; display: flex; align-items: center; gap: 8px; }
        .btn-print { background: var(--primary-mint); color: white; }
        .btn-close { background: #eee; color: #333; }

        @@media print {
            body { background: white; padding: 0; }
            .action-btns { display: none; } 
            .invoice-wrapper { box-shadow: none; padding: 20px; }
            .invoice-header { border-bottom: none; }
        }
    </style>
</head>
<body>

<div class="invoice-wrapper">
    <div class="invoice-header">
        <div class="brand-section">
            <img src="~/images/02.png" alt="Velvy Skin Logo" class="brand-logo">
            <div class="brand-info">
                <p>Mỹ phẩm thiên nhiên cao cấp<br>
                Số 1 Đường D1, Khu Công Nghệ Cao, TP.HCM<br>
                Hotline: 0123 456 789 | velvyskin.vn</p>
            </div>
        </div>
        <div class="invoice-status">
            <div class="status-badge">@statusVN</div>
            <div class="invoice-meta">
                <p>Mã hóa đơn: <strong>#VS-@Model.Id</strong></p>
                <p>Ngày đặt: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                <p>Thanh toán: @Model.PaymentMethod</p>
            </div>
        </div>
    </div>

    <div class="info-grid">
        <div class="info-block">
            <h4>Khách hàng</h4>
            <p>@Model.CustomerName</p>
            <p>@Model.PhoneNumber</p>
        </div>
        <div class="info-block">
            <h4>Địa chỉ giao hàng</h4>
            <p>@Model.ShippingAddress</p>
            @if(!string.IsNullOrEmpty(Model.Note)){
                <p>Ghi chú: @Model.Note</p>
            }
        </div>
    </div>

    <table class="invoice-table">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th width="100">Đơn giá</th>
                <th width="80" style="text-align: center;">SL</th>
                <th width="120" style="text-align: right;">Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var detail in Model.OrderDetails)
            {
                <tr>
                    <td><span class="item-name">@detail.Product.Name</span></td>
                    <td>@detail.UnitPrice.ToString("N0")đ</td>
                    <td style="text-align: center;">@detail.Quantity.ToString("D2")</td>
                    <td style="text-align: right;">@((detail.UnitPrice * detail.Quantity).ToString("N0"))đ</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="invoice-summary">
        <div class="summary-box">
            <div class="summary-row">
                <span>Tạm tính:</span>
                <span>@subTotal.ToString("N0")đ</span>
            </div>
            <div class="summary-row">
                <span>Phí vận chuyển:</span>
                <span>@shippingFee.ToString("N0")đ</span>
            </div>
            @if(discount > 0)
            {
                <div class="summary-row">
                    <span>Giảm giá:</span>
                    <span style="color: #e74c3c;">- @discount.ToString("N0")đ</span>
                </div>
            }
            <div class="summary-row total">
                <span>Tổng cộng:</span>
                <span>@Model.TotalAmount.ToString("N0")đ</span>
            </div>
        </div>
    </div>

    <div class="invoice-footer">
        <p class="thanks-msg">Cảm ơn bạn đã lựa chọn Velvy Skin!</p>
        <p style="font-size: 12px; color: #aaa;">Vui lòng giữ hóa đơn này để đổi trả trong vòng 7 ngày.</p>
    </div>

    <div class="action-btns">
        <button onclick="window.print()" class="btn btn-print">
            <i class="fa-solid fa-print"></i> In hóa đơn
        </button>
        <button onclick="window.close()" class="btn btn-close">
            <i class="fa-solid fa-xmark"></i> Đóng trang
        </button>
    </div>
</div>

</body>
</html>