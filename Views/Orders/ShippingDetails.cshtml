@model VelvySkinWeb.Models.Order
@{
    ViewData["Title"] = "Chi tiết vận chuyển #" + Model.Id;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 26px; color: var(--dark-mint); margin: 0; }
    
    .back-btn { text-decoration: none; color: #888; font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; margin-bottom: 20px; transition: 0.3s;}
    .back-btn:hover { color: var(--primary-mint); }

    .status-shipping { background: #e1f5fe; color: #3498db; padding: 8px 20px; border-radius: 30px; font-size: 12px; font-weight: 700; display: flex; align-items: center; gap: 8px; }

    .grid-layout { display: grid; grid-template-columns: 1.5fr 1fr; gap: 25px; }

    .card { background: white; border-radius: 25px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); margin-bottom: 25px; border: 1px solid #f1f1f1; }
    .card-title { font-weight: 700; font-size: 14px; text-transform: uppercase; color: var(--dark-mint); margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }

    .timeline { position: relative; padding-left: 30px; margin-top: 20px; }
    .timeline::before { content: ''; position: absolute; left: 7px; top: 5px; width: 2px; height: 90%; background: #eee; }
    .timeline-item { position: relative; margin-bottom: 25px; }
    .timeline-dot { position: absolute; left: -30px; top: 4px; width: 16px; height: 16px; border-radius: 50%; background: #ddd; border: 3px solid white; z-index: 2; }
    .timeline-dot.active { background: #3498db; box-shadow: 0 0 0 4px rgba(52, 152, 219, 0.2); }
    .timeline-info { font-size: 13px; }
    .timeline-time { font-size: 11px; color: #aaa; font-weight: 600; }
    .timeline-content { font-weight: 600; margin-top: 3px; }

    /* Shipper Box Styles */
    .shipper-section { background: var(--light-mint); padding: 20px; border-radius: 15px; margin-top: 15px; border: 1px dashed var(--primary-mint); }
    .shipper-avatar { width: 45px; height: 45px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; color: var(--primary-mint); border: 1px solid #eee; }
    .shipper-detail { flex: 1; font-size: 13px; }
    .btn-call { background: #3498db; color: white; border: none; padding: 8px 12px; border-radius: 8px; cursor: pointer; font-size: 12px; font-weight: 600; transition: 0.3s; text-decoration: none; display: inline-block; text-align: center;}
    .btn-call:hover { opacity: 0.8; color: white;}

    .product-mini { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; font-size: 13px; border-bottom: 1px solid #fafafa; padding-bottom: 8px;}
    .product-mini img { width: 40px; height: 40px; border-radius: 8px; object-fit: cover; border: 1px solid #eee;}

    .info-row { display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 13px; }
    .info-label { color: #888; }
    .info-value { font-weight: 600; }
    .total-box { border-top: 1px dashed #eee; margin-top: 15px; padding-top: 15px; }

    @@media (max-width: 800px) { .grid-layout { grid-template-columns: 1fr; } }
</style>

<a asp-controller="Admin" asp-action="Orders" class="back-btn">
    <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
</a>

<div class="order-header">
    <div>
        <h1 class="page-title">Đơn hàng #@Model.Id</h1>
        <p style="font-size: 13px; color: #888; margin-top: 5px;">Mã vận đơn: <strong style="color: #333;">VVS-@Model.Id-@DateTime.Now.ToString("MMdd")</strong></p>
    </div>
    <div class="status-shipping">
        <i class="fa-solid fa-truck-fast"></i> ĐANG GIAO HÀNG
    </div>
</div>

<div class="grid-layout">
    <div class="left-col">
        <div class="card">
            <div class="card-title"><i class="fa-solid fa-map-location-dot"></i> Hành trình vận chuyển </div>
            
            @if (string.IsNullOrEmpty(Model.ShipperName))
            {
                <div style="padding: 40px 20px; text-align: center; color: #888; background: #fdfdfd; border-radius: 15px; border: 1px dashed #ddd;">
                    <i class="fa-solid fa-box-open" style="font-size: 40px; color: #ccc; margin-bottom: 15px; display: block;"></i>
                    <p style="font-weight: 600; color: #555; margin-bottom: 5px;">Đơn hàng đang chờ bàn giao cho ĐVVC</p>
                    <p style="font-size: 13px;">(Vui lòng cập nhật thông tin Shipper bên dưới để kích hoạt hành trình)</p>
                </div>
            }
            else
            {
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-dot active"></div>
                        <div class="timeline-info">
                            <div class="timeline-time">Hôm nay, @DateTime.Now.ToString("hh:mm tt")</div>
                            <div class="timeline-content" style="color: #3498db;">Shipper @Model.ShipperName đang đi giao đến khách hàng</div>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-info">
                            <div class="timeline-time">@DateTime.Now.AddHours(-5).ToString("dd/MM/yyyy, hh:mm tt")</div>
                            <div class="timeline-content">Đã rời kho phân loại TP. Hồ Chí Minh </div>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-info">
                            <div class="timeline-time">@Model.OrderDate.AddHours(2).ToString("dd/MM/yyyy, hh:mm tt")</div>
                            <div class="timeline-content">Lấy hàng thành công từ Shop</div>
                        </div>
                    </div>
                </div>
            }

            <div class="shipper-section">
                @if (string.IsNullOrEmpty(Model.ShipperName) || string.IsNullOrEmpty(Model.ShipperPhone))
                {
                    <h4 style="font-size: 13px; color: var(--dark-mint); margin-bottom: 10px; font-weight: 700;"><i class="fa-solid fa-motorcycle"></i> Cập nhật thông tin Shipper</h4>
                    <form asp-controller="Orders" asp-action="UpdateShipperInfo" method="post" style="display: flex; gap: 10px; flex-direction: column;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="text" name="shipperName" placeholder="Tên Shipper..." required style="padding: 10px 15px; border-radius: 8px; border: 1px solid #ccc; font-size: 13px; outline: none;" />
                        <input type="text" name="shipperPhone" placeholder="Số điện thoại..." required style="padding: 10px 15px; border-radius: 8px; border: 1px solid #ccc; font-size: 13px; outline: none;" />
                        <button type="submit" class="btn-call" style="width: 100%;"><i class="fa-solid fa-floppy-disk"></i> Lưu thông tin</button>
                    </form>
                }
                else
                {
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <div class="shipper-avatar"><i class="fa-solid fa-user-ninja"></i></div>
                        <div class="shipper-detail">
                            <div style="font-weight: 800; color: #222; font-size: 15px;">@Model.ShipperName</div>
                            <div style="font-size: 12px; color: #666; margin-top: 3px;">Nhân viên giao vận</div>
                            <div style="font-size: 13px; color: var(--dark-mint); font-weight: 600; margin-top: 3px;"><i class="fa-solid fa-phone-volume"></i> @Model.ShipperPhone</div>
                        </div>
                        
                        <a href="tel:@Model.ShipperPhone" class="btn-call">
                            <i class="fa-solid fa-phone"></i> Gọi ngay
                        </a>
                    </div>
                    
                    <div style="margin-top: 15px; text-align: right; border-top: 1px dashed #ccc; padding-top: 10px;">
                        <a href="javascript:void(0);" onclick="document.getElementById('editShipperForm').style.display='flex'" style="font-size: 12px; color: var(--danger); text-decoration: underline;">Sửa lại thông tin Shipper</a>
                    </div>
                    
                    <form id="editShipperForm" asp-controller="Orders" asp-action="UpdateShipperInfo" method="post" style="display: none; gap: 10px; flex-direction: column; margin-top: 15px;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="text" name="shipperName" value="@Model.ShipperName" required style="padding: 10px 15px; border-radius: 8px; border: 1px solid #ccc; font-size: 13px;" />
                        <input type="text" name="shipperPhone" value="@Model.ShipperPhone" required style="padding: 10px 15px; border-radius: 8px; border: 1px solid #ccc; font-size: 13px;" />
                        <button type="submit" class="btn-call" style="width: 100%;"><i class="fa-solid fa-floppy-disk"></i> Cập nhật thay đổi</button>
                    </form>
                }
            </div>
            </div>

        <div class="card">
            <div class="card-title"><i class="fa-solid fa-box"></i> Kiện hàng (@(Model.OrderDetails?.Count ?? 0) sản phẩm)</div>
            @if(Model.OrderDetails != null)
            {
                foreach(var item in Model.OrderDetails)
                {
                    <div class="product-mini">
                        <img src="@(item.Product?.ImageUrl ?? "https://via.placeholder.com/40")" alt="sp">
                        <div style="flex:1"><strong>@(item.Product?.Name ?? "Sản phẩm")</strong></div>
                        <div style="font-weight: 700; color: var(--primary-mint);">x@(item.Quantity)</div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="right-col">
        <div class="card">
            <div class="card-title"><i class="fa-solid fa-user"></i> Người nhận hàng</div>
            <div class="info-row">
                <span class="info-label">Họ tên:</span>
                <span class="info-value">@Model.CustomerName</span>
            </div>
            <div class="info-row">
                <span class="info-label">SĐT:</span>
                <span class="info-value">@Model.PhoneNumber</span>
            </div>
            <div class="info-row" style="align-items: flex-start;">
                <span class="info-label" style="white-space: nowrap; margin-right: 15px;">Địa chỉ:</span>
                <span class="info-value" style="text-align: right; line-height: 1.5;">@Model.ShippingAddress</span>
            </div>
        </div>

        <div class="card">
            <div class="card-title"><i class="fa-solid fa-credit-card"></i> Thanh toán</div>
            <div class="info-row">
                <span class="info-label">Phương thức:</span>
                <span class="info-value">@(Model.PaymentMethod ?? "Thanh toán khi nhận hàng (COD)")</span>
            </div>
            <div class="total-box">
                <div class="info-row" style="font-size: 16px; margin-top: 10px;">
                    <span style="font-weight: 700; color: var(--dark-mint);">Cần thu hộ:</span>
                    <span style="font-weight: 700; color: #3498db;">@Model.TotalAmount.ToString("N0")đ</span>
                </div>
            </div>
            
            <form method="post" asp-controller="Orders" asp-action="UpdateStatus">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" name="newStatus" value="Completed" class="btn-call" style="width: 100%; margin-top: 20px; background: var(--primary-mint); font-size: 14px; font-weight: 700; padding: 12px;">
                    <i class="fa-solid fa-circle-check"></i> Đánh dấu là đã giao
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                Swal.fire({
                    title: 'Đã bàn giao cho Shipper!',
                    text: '@Html.Raw(TempData["SuccessMsg"])',
                    icon: 'success',
                    confirmButtonColor: '#2ec4b6', 
                    timer: 3500, 
                    backdrop: `rgba(0,0,0,0.4)` 
                });
            </text>
        }
    </script>
}