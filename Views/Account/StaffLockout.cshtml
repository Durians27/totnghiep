@{
    ViewData["Title"] = "Tài khoản bị vô hiệu hóa";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<div style="min-height: 80vh; display: flex; align-items: center; justify-content: center; background: #f8f9fa; padding: 20px;">
    <div style="background: white; padding: 50px 40px; border-radius: 20px; box-shadow: 0 15px 40px rgba(0,0,0,0.08); text-align: center; max-width: 500px; width: 100%; position: relative; overflow: hidden;">
        
        <div style="position: absolute; top: 0; left: 0; right: 0; height: 6px; background: #ef4444;"></div>

        <div style="width: 90px; height: 90px; background: #fff0f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 25px;">
            <i class="fa-solid fa-user-lock" style="font-size: 40px; color: #ef4444;"></i>
        </div>

        <h1 style="font-family: 'Playfair Display', serif; color: #333; font-size: 28px; margin-bottom: 10px;">Truy Cập Bị Từ Chối</h1>
        <p style="color: #ef4444; font-weight: 700; font-size: 14px; letter-spacing: 1px; margin-bottom: 25px; text-transform: uppercase;">
            TÀI KHOẢN NỘI BỘ (STAFF) ĐÃ BỊ VÔ HIỆU HÓA
        </p>

        <div style="background: #f1f5f9; padding: 20px; border-radius: 12px; margin-bottom: 30px; text-align: left;">
            <p style="color: #555; font-size: 14px; margin-bottom: 8px; line-height: 1.6;">
                Xin chào <b>@ViewBag.UserEmail</b>,
            </p>
            <p style="color: #555; font-size: 14px; margin-bottom: 0; line-height: 1.6;">
                Quyền truy cập vào hệ thống quản trị <b>Velvy Skin Admin Panel</b> của bạn đã bị thu hồi bởi Giám đốc / Quản trị viên. Bạn không còn quyền thực hiện các thao tác xử lý nghiệp vụ trên hệ thống.
            </p>
        </div>

        <p style="color: #888; font-size: 13px; margin-bottom: 30px; font-style: italic;">
            * Nếu bạn cho rằng đây là sự nhầm lẫn, vui lòng liên hệ trực tiếp với Giám đốc (Admin) qua các kênh liên lạc nội bộ của công ty.
        </p>

        <div style="display: flex; gap: 15px; justify-content: center;">
            <a href="~/Home/Index" style="padding: 12px 25px; background: #f1f1f1; color: #555; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 14px; transition: 0.3s;" onmouseover="this.style.background='#e5e5e5'" onmouseout="this.style.background='#f1f1f1'">
                Về trang chủ
            </a>
            <a href="~/Account/Login" style="padding: 12px 25px; background: var(--primary-mint); color: white; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 14px; transition: 0.3s; box-shadow: 0 4px 10px rgba(46, 196, 182, 0.3);" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                Đổi tài khoản khác
            </a>
        </div>
    </div>
</div>