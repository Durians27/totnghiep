@{ ViewData["Title"] = "Thiết lập mật khẩu mới"; }

<style>
    .reset-main-wrapper { flex: 1; display: flex; align-items: center; justify-content: center; padding: 60px 0; }
    .reset-container { background: var(--white); width: 100%; max-width: 450px; padding: 45px; border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.06); text-align: center; position: relative; }
    .reset-container::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 5px; background: var(--primary-mint); }
    .icon-circle { width: 70px; height: 70px; background: var(--light-mint); color: var(--primary-mint); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 30px; margin: 0 auto 25px; }
    .reset-container h2 { font-family: 'Playfair Display', serif; font-size: 26px; color: #333; margin-bottom: 10px; }
    .subtitle { font-size: 14px; color: #777; margin-bottom: 30px; }
    .form-group { text-align: left; margin-bottom: 22px; position: relative; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 8px; color: #555; }
    .input-group { position: relative; display: flex; align-items: center; }
    .input-group i.left-icon { position: absolute; left: 15px; color: var(--primary-mint); font-size: 16px; }
    .input-group i.toggle-password { position: absolute; right: 15px; color: #ccc; cursor: pointer; transition: 0.3s; }
    .input-group i.toggle-password:hover { color: var(--primary-mint); }
    .input-group input { width: 100%; height: 50px; padding: 0 45px 0 45px; border: 1px solid #eee; border-radius: 12px; outline: none; background: #f9f9f9; font-size: 14px; transition: 0.3s; }
    .input-group input:focus { border-color: var(--primary-mint); background: #fff; box-shadow: 0 0 0 4px rgba(46, 196, 182, 0.1); }
    .btn-submit { width: 100%; padding: 16px; background: var(--primary-mint); color: white; border: none; border-radius: 12px; font-weight: 700; font-size: 15px; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; transition: 0.3s; box-shadow: 0 8px 20px rgba(46, 196, 182, 0.3); margin-top: 10px; }
    .btn-submit:hover { background: var(--dark-mint); transform: translateY(-2px); }
</style>

<div class="reset-main-wrapper">
    <div class="reset-container">
        <div class="icon-circle"><i class="fa-solid fa-lock-open"></i></div>
        <h2>Thiết lập mật khẩu mới</h2>
        <p class="subtitle">Vui lòng tạo mật khẩu mới mạnh mẽ hơn cho tài khoản <strong>@ViewBag.Email</strong>.</p>

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" name="email" value="@ViewBag.Email" />
            
            <div class="form-group">
                <label>Mật khẩu mới</label>
                <div class="input-group">
                    <i class="fa-solid fa-lock left-icon"></i>
                    <input type="password" name="newPassword" id="pass" placeholder="Tối thiểu 8 ký tự" required>
                    <i class="fa-regular fa-eye toggle-password" onclick="togglePass('pass', this)"></i>
                </div>
            </div>

            <div class="form-group">
                <label>Xác nhận mật khẩu</label>
                <div class="input-group">
                    <i class="fa-solid fa-shield-check left-icon"></i>
                    <input type="password" name="confirmPassword" id="confirm_pass" placeholder="Nhập lại mật khẩu mới" required>
                    <i class="fa-regular fa-eye toggle-password" onclick="togglePass('confirm_pass', this)"></i>
                </div>
            </div>

            <button type="submit" class="btn-submit">Lưu mật khẩu & Đăng nhập</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function togglePass(id, icon) {
            const input = document.getElementById(id);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = "password";
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
}