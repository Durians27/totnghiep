@model VelvySkinWeb.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    /* CSS DÀNH RIÊNG CHO FORM ĐĂNG NHẬP */
    .login-main-wrapper {
        flex: 1; display: flex; align-items: center; justify-content: center; padding: 60px 0;
    }

    .login-container {
        background: var(--white); width: 100%; max-width: 450px; padding: 40px; 
        border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.08); 
        text-align: center; position: relative; overflow: hidden;
    }

    .login-container::before {
        content: ''; position: absolute; top: 0; left: 0; 
        width: 100%; height: 5px; background: var(--primary-mint);
    }

    .login-container h2 { font-family: 'Playfair Display', serif; font-size: 28px; margin-bottom: 10px; color: #333; }
    p.subtitle { font-size: 14px; color: #888; margin-bottom: 30px; }

    .form-group { text-align: left; margin-bottom: 20px; position: relative; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 8px; color: #555; }
    .form-group i { position: absolute; left: 15px; top: 38px; color: var(--primary-mint); }
    
    .form-group input[type="text"], 
    .form-group input[type="password"],
    .form-group input[type="email"] {
        width: 100%; padding: 12px 15px 12px 40px; border: 1px solid #eee;
        border-radius: 10px; outline: none; font-family: inherit; 
        transition: var(--transition); background: #f9f9f9;
    }

    .form-group input:focus {
        border-color: var(--primary-mint); background: #fff; 
        box-shadow: 0 0 0 4px rgba(46, 196, 182, 0.1);
    }

    .options { display: flex; justify-content: space-between; align-items: center; font-size: 13px; margin-bottom: 25px; }
    .options a { color: var(--primary-mint); text-decoration: none; font-weight: 600; }

    .btn-login {
        width: 100%; padding: 15px; background: var(--primary-mint); color: white;
        border: none; border-radius: 10px; font-weight: 700; font-size: 15px;
        text-transform: uppercase; letter-spacing: 1px; cursor: pointer; 
        transition: var(--transition); box-shadow: 0 5px 15px rgba(46, 196, 182, 0.3);
    }
    .btn-login:hover { background: var(--dark-mint); transform: translateY(-2px); }

    .divider { margin: 30px 0; position: relative; height: 1px; background: #eee; }
    .divider span {
        position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
        background: #fff; padding: 0 15px; font-size: 12px; color: #999;
    }

    .social-login { display: flex; gap: 15px; justify-content: center; }
    .social-btn {
        flex: 1; padding: 10px; border: 1px solid #eee; border-radius: 10px;
        background: #fff; cursor: pointer; transition: 0.3s;
        display: flex; align-items: center; justify-content: center; gap: 10px;
        font-size: 14px; font-weight: 500;
    }
    .social-btn:hover { background: #f5f5f5; border-color: #ddd; }
    .social-btn img { width: 20px; }

    .footer-link { margin-top: 20px; font-size: 14px; }
    .footer-link a { color: var(--accent-pink); font-weight: 800; text-decoration: none; transition: 0.3s; }
    .footer-link a:hover { text-decoration: underline; }

    /* CSS Báo lỗi của C# Backend */
    .text-danger { font-size: 12px; color: #dc3545; margin-top: 4px; display: block; }
    .validation-summary-errors { color: #dc3545; font-size: 13px; text-align: left; margin-bottom: 15px; background: #ffe6e6; padding: 10px; border-radius: 8px;}
    .validation-summary-errors ul { list-style: none; padding: 0; margin: 0; }
</style>

<div class="login-main-wrapper">
    <div class="login-container">
        <h2>ĐĂNG NHẬP</h2>
        <p class="subtitle">Đăng nhập để nhận tư vấn da cá nhân hóa.</p>

        <form asp-action="Login" method="post" asp-route-returnurl="@ViewData["ReturnUrl"]">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="form-group">
                <label asp-for="Email">Email của bạn</label>
                <i class="fa-regular fa-envelope"></i>
                <input asp-for="Email" placeholder="example@gmail.com" required>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Mật khẩu</label>
                <i class="fa-solid fa-lock"></i>
                <input asp-for="Password" type="password" placeholder="••••••••" required>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="options">
                <label style="display: flex; align-items: center; gap: 5px; cursor: pointer;">
                    <input asp-for="RememberMe" style="accent-color: var(--primary-mint);"> 
                    @Html.DisplayNameFor(m => m.RememberMe)
                </label>
                <a asp-controller="Account" asp-action="ForgotPassword">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn-login">Đăng nhập</button>
        </form>

        <div class="divider">
            <span>Hoặc đăng nhập với</span>
        </div>

        <div class="social-login">
            <button class="social-btn" type="button">
                <img src="https://cdn-icons-png.flaticon.com/512/300/300221.png" alt="Google"> Google
            </button>
            <button class="social-btn" type="button">
                <img src="https://cdn-icons-png.flaticon.com/512/733/733547.png" alt="Facebook"> Facebook
            </button>
        </div>

        <div class="footer-link">
            Chưa có tài khoản? <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}