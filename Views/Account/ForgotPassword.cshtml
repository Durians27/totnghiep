@{
    ViewData["Title"] = "Quên mật khẩu";
}

<style>
    /* CSS DÀNH RIÊNG CHO FORM QUÊN MẬT KHẨU */
    .forgot-wrapper {
        flex: 1; display: flex; align-items: center; justify-content: center; padding: 60px 5%;
    }

    .forgot-card {
        background: var(--white); width: 100%; max-width: 450px; padding: 40px;
        border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        text-align: center; position: relative; overflow: hidden;
    }

    .forgot-card::before {
        content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 5px;
        background: var(--primary-mint);
    }

    .icon-box {
        width: 70px; height: 70px; background: var(--light-mint, #cbf3f0);
        color: var(--primary-mint); border-radius: 50%; display: flex;
        align-items: center; justify-content: center; font-size: 30px; margin: 0 auto 20px;
    }

    .forgot-card h2 { font-family: 'Playfair Display', serif; font-size: 26px; margin-bottom: 10px; }
    .subtitle { font-size: 14px; color: #777; margin-bottom: 30px; line-height: 1.5; }

    .form-group { text-align: left; margin-bottom: 25px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 8px; color: #555; }
    
    .input-group { position: relative; display: flex; align-items: center; }
    .input-group i { position: absolute; left: 15px; color: var(--primary-mint); font-size: 16px; }
    
    .input-group input { 
        width: 100%; height: 50px; padding: 0 15px 0 45px; border: 1px solid #eee; 
        border-radius: 12px; outline: none; background: #f9f9f9; font-size: 14px; transition: 0.3s;
    }
    .input-group input:focus { border-color: var(--primary-mint); background: #fff; box-shadow: 0 0 0 4px rgba(46, 196, 182, 0.1); }

    .btn-reset {
        width: 100%; padding: 16px; background: var(--primary-mint); color: white;
        border: none; border-radius: 12px; font-weight: 700; cursor: pointer;
        text-transform: uppercase; letter-spacing: 1px; transition: 0.3s;
    }
    .btn-reset:hover { background: var(--dark-mint); transform: translateY(-2px); }

    .back-to-login { margin-top: 25px; font-size: 14px; }
    .back-to-login a { 
        color: var(--accent-pink); text-decoration: none; font-weight: 700; 
        display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.3s;
    }
    .back-to-login a:hover { text-decoration: underline; transform: translateX(-5px); }
</style>

<div class="forgot-wrapper">
    <div class="forgot-card">
        <div class="icon-box">
            <i class="fa-solid fa-key"></i>
        </div>
        <h2>Quên mật khẩu?</h2>
        <p class="subtitle">Đừng lo lắng! Hãy nhập email hoặc số điện thoại đã đăng ký, chúng tôi sẽ gửi mã khôi phục cho bạn.</p>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success text-start" style="font-size: 13px; border-radius: 10px;">
                <i class="fa-solid fa-circle-check"></i> @TempData["Message"]
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            <div class="form-group">
                <label>Email hoặc Số điện thoại</label>
                <div class="input-group">
                    <i class="fa-regular fa-envelope"></i>
                    <input type="text" name="email" placeholder="Nhập thông tin của bạn..." required>
                </div>
            </div>

            <button type="submit" class="btn-reset">Gửi mã xác nhận</button>
        </form>

        <div class="back-to-login">
            <a asp-controller="Account" asp-action="Login">
                <i class="fa-solid fa-arrow-left-long"></i> Quay lại Đăng nhập
            </a>
        </div>
    </div>
</div>