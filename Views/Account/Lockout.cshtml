@{
    ViewData["Title"] = "Tài khoản bị khóa";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Trả về giao diện khách
}

<div style="min-height: 80vh; display: flex; align-items: center; justify-content: center; background-color: #f9f9f9; padding: 40px 15px;">
    <div style="background: white; max-width: 500px; width: 100%; border-radius: 25px; padding: 50px 40px; text-align: center; box-shadow: 0 20px 40px rgba(0,0,0,0.08);">
        
        <i class="fa-solid fa-lock" style="font-size: 70px; color: #d32f2f; margin-bottom: 20px;"></i>
        <h2 style="font-family: 'Playfair Display', serif; color: #d32f2f; font-weight: 700; margin-bottom: 10px;">TÀI KHOẢN BỊ TẠM KHÓA</h2>
        <p style="color: #666; font-size: 15px; margin-bottom: 30px;">Tài khoản <strong>@ViewBag.UserEmail</strong> của bạn đã bị vô hiệu hóa do vi phạm chính sách hoạt động.</p>

        <div style="background: #fff0f0; border: 1px solid #f5c2c7; border-radius: 15px; padding: 20px; text-align: left; margin-bottom: 35px;">
            <p style="margin: 0 0 10px; font-size: 14px; color: #333;"><strong><i class="fa-solid fa-circle-exclamation" style="color: #d32f2f;"></i> Nguyên nhân:</strong> @ViewBag.Reason</p>
            <p style="margin: 0; font-size: 14px; color: #333;">
                <strong><i class="fa-solid fa-clock" style="color: #d32f2f;"></i> Thời hạn mở khóa:</strong> 
                @if (ViewBag.LockEnd != null && ViewBag.LockEnd < DateTimeOffset.MaxValue)
                {
                    <span style="color: #d32f2f; font-weight: bold;">@(((DateTimeOffset)ViewBag.LockEnd).ToLocalTime().ToString("HH:mm - dd/MM/yyyy"))</span>
                }
                else
                {
                    <span style="color: #d32f2f; font-weight: bold;">Khóa vĩnh viễn</span>
                }
            </p>
        </div>

        @if (TempData["AppealSuccess"] != null)
        {
            <div class="alert alert-success" style="border-radius: 10px; font-size: 14px;">
                <i class="fa-solid fa-circle-check"></i> @TempData["AppealSuccess"]
            </div>
        }
        else
        {
            <p style="font-size: 13px; color: #888;">Bạn cho rằng đây là sự nhầm lẫn?</p>
            <button type="button" onclick="document.getElementById('appealForm').style.display='block'; this.style.display='none';" style="background: var(--primary-mint); color: white; border: none; padding: 12px 30px; border-radius: 12px; font-weight: 600; cursor: pointer; transition: 0.3s; font-family: inherit;">
                Gửi yêu cầu kháng cáo
            </button>

            <form id="appealForm" asp-controller="Account" asp-action="SubmitAppeal" method="post" style="display: none; text-align: left; margin-top: 20px; animation: fadeIn 0.5s;">
                <input type="hidden" name="email" value="@ViewBag.UserEmail" />
                <label style="font-size: 13px; font-weight: 600; color: #555; margin-bottom: 8px; display: block;">Lý do giải trình của bạn:</label>
                <textarea name="appealReason" rows="3" required placeholder="Vui lòng nhập chi tiết sự việc..." style="width: 100%; border-radius: 10px; border: 1px solid #ddd; padding: 12px; font-family: inherit; font-size: 14px; margin-bottom: 15px; outline: none;"></textarea>
                <button type="submit" style="background: var(--dark-mint); color: white; border: none; padding: 12px; border-radius: 12px; font-weight: 600; width: 100%; cursor: pointer;">Gửi Đơn Kháng Cáo</button>
            </form>
        }

        <div style="margin-top: 30px; border-top: 1px solid #eee; padding-top: 20px;">
            <a asp-controller="Home" asp-action="Index" style="color: #888; text-decoration: none; font-size: 14px; font-weight: 600;"><i class="fa-solid fa-arrow-left"></i> Quay về Trang chủ</a>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
</style>