@model VelvySkinWeb.Models.Category

@{
    ViewData["Title"] = "Sửa Danh Mục";
}

<div class="container mt-5" style="max-width: 600px; background: #fff; padding: 30px; border-radius: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
    <h2 style="color: var(--dark-mint); font-family: 'Playfair Display', serif;"><i class="fa-solid fa-pen-to-square"></i> Cập nhật Danh mục</h2>
    <hr style="border-color: var(--light-mint);" />
    
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        
        <div class="form-group mb-3">
            <label asp-for="Name" class="control-label fw-bold" style="color: #555;">Tên Danh Mục</label>
            <input asp-for="Name" class="form-control" style="border-radius: 8px; border: 1.5px solid #eee;" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        
        <div class="form-group mb-4">
            <label asp-for="Description" class="control-label fw-bold" style="color: #555;">Mô tả chi tiết</label>
            <textarea asp-for="Description" class="form-control" rows="4" style="border-radius: 8px; border: 1.5px solid #eee;"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        
        <div class="form-group d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4 py-2" style="background-color: var(--primary-mint); border: none; border-radius: 30px; font-weight: 600;">
                <i class="fa-solid fa-floppy-disk"></i> Lưu Thay Đổi
            </button>
            <a asp-action="Index" class="btn btn-light px-4 py-2" style="border-radius: 30px; font-weight: 600; border: 1px solid #ddd;">Hủy và quay lại</a>
        </div>
    </form>
</div>