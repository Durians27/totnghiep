@model IEnumerable<VelvySkinWeb.Models.Category>

@{
    ViewData["Title"] = "Danh sách Danh mục";
}

<div class="container mt-4">
    <h2 style="color: var(--velvy-primary); font-family: 'Playfair Display', serif;">Quản lý Danh mục Sản phẩm</h2>
    <hr />
    
    <p>
        <a asp-action="Create" class="btn btn-velvy">Tạo Danh mục mới</a>
    </p>
    
    <table class="table table-hover table-bordered bg-white shadow-sm mt-3">
        <thead class="table-light">
            <tr>
                <th>Tên Danh mục</th>
                <th>Mô tả chi tiết</th>
                <th class="text-center">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td class="fw-bold">@item.Name</td>
                    <td>@item.Description</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>