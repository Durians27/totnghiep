@model List<VelvySkinWeb.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ Hàng";
}

<style>
    .cart-container { padding: 30px 5%; max-width: 1400px; margin: 0 auto; min-height: 50vh; font-family: 'Montserrat', sans-serif;}
    .page-title { font-family: 'Playfair Display', serif; font-size: 32px; margin-bottom: 10px; color: #222; }

    .cart-table { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
    .cart-table th, .cart-table td { padding: 15px; text-align: left; border-bottom: 1px solid #eee; vertical-align: middle;}
    .cart-table th { background: #f9f9f9; font-weight: 600; text-transform: uppercase; font-size: 13px; color: #555;}
    .product-info { display: flex; align-items: center; gap: 15px; }
    .product-img { width: 80px; height: 80px; object-fit: contain; border-radius: 8px; border: 1px solid #f0f0f0; background: white;}
    .product-name { font-weight: 600; color: var(--dark-mint); font-size: 16px;}
    .price { color: var(--primary-mint); font-weight: 600; font-size: 16px;}
    
    .remove-btn { color: #ff4d4d; text-decoration: none; cursor: pointer; transition: 0.3s; padding: 8px 12px; border-radius: 5px; border: none; background: transparent; font-size: 16px;}
    .remove-btn:hover { background: #fff0f0; }

    /* CHECKBOX STYLES */
    .custom-checkbox { width: 20px; height: 20px; cursor: pointer; accent-color: var(--primary-mint); }

    .cart-bottom-area { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 20px; margin-top: 20px;}
    
    /* NÚT XÓA TOÀN BỘ ĐÃ ĐƯỢC LÀM ĐẸP LẠI */
    .btn-clear-cart { display: inline-flex; align-items: center; gap: 8px; background: white; color: #ff4d4d; border: 1px solid #ff4d4d; padding: 10px 20px; border-radius: 30px; font-weight: 600; font-size: 14px; text-decoration: none; transition: 0.3s; }
    .btn-clear-cart:hover { background: #ff4d4d; color: white; box-shadow: 0 4px 10px rgba(255, 77, 77, 0.2); }

    .cart-summary { background: white; padding: 25px; border-radius: 15px; box-shadow: 0 5px 25px rgba(0,0,0,0.05); width: 100%; max-width: 450px; border: 1px solid #eee;}
    .cart-summary h3 { font-size: 18px; margin-bottom: 15px; border-bottom: 1px solid #eee; padding-bottom: 10px; color: var(--dark-mint);}
    .summary-row { display: flex; justify-content: space-between; margin-bottom: 15px; color: #555;}
    .summary-total { font-weight: 700; font-size: 20px; color: var(--accent-pink); border-top: 1px solid #eee; padding-top: 15px; margin-top: 15px; }
    
    .btn-checkout { display: block; width: 100%; padding: 15px; background: var(--dark-mint); color: white; border: none; border-radius: 30px; font-weight: 700; font-size: 16px; cursor: pointer; transition: 0.3s; margin-top: 20px; text-align: center; text-decoration: none;}
    .btn-checkout:hover { background: var(--primary-mint); box-shadow: 0 8px 20px rgba(46,196,182,0.3); color: white;}
    .btn-checkout.disabled { background: #ccc; cursor: not-allowed; box-shadow: none; pointer-events: none;}

    .empty-cart { text-align: center; padding: 80px 0; color: #777; }
    .empty-cart i { font-size: 60px; color: #ddd; margin-bottom: 20px; }
    .empty-cart p { font-size: 18px; margin-bottom: 20px; color: #555;}
    .btn-shopping { background: var(--primary-mint); color: white; padding: 12px 30px; border-radius: 30px; text-decoration: none; font-weight: 600; display: inline-block; transition: 0.3s;}
    .btn-shopping:hover { background: var(--dark-mint); color: white;}

    @@media (max-width: 768px) {
        .cart-table th { display: none; }
        .cart-table td { display: block; text-align: right; }
        .cart-table td::before { content: attr(data-label); float: left; font-weight: bold; text-transform: uppercase; font-size: 12px; color: #888;}
        .cart-table .product-info { justify-content: flex-end; text-align: right;}
        .cart-bottom-area { flex-direction: column; align-items: flex-end; }
        .cart-summary { max-width: 100%; }
    }
</style>

<div class="cart-container">
    <div class="breadcrumb" style="margin-bottom: 30px; font-size: 14px; color: #888;">
        <a asp-controller="Home" asp-action="Index" style="color: var(--primary-mint); text-decoration: none;"><i class="fa-solid fa-house-chimney"></i> Trang chủ</a> 
        <span style="margin: 0 10px;">/</span> <span style="color: #444; font-weight: 600;">Giỏ hàng của bạn</span>
    </div>

    <h1 class="page-title">Giỏ Hàng Của Bạn</h1>

    @if (TempData["ErrorMsg"] != null)
    {
        <div class="alert alert-danger" style="border-radius: 10px; background: #fff0f0; color: #d32f2f; padding: 15px; margin-bottom: 20px; border: 1px solid #f5c2c7;">
            <i class="fa-solid fa-triangle-exclamation"></i> @TempData["ErrorMsg"]
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="empty-cart">
            <i class="fa-solid fa-cart-arrow-down"></i>
            <p>Oops! Giỏ hàng của bạn đang trống trơn.</p>
            <a asp-controller="Home" asp-action="Index" class="btn-shopping">Tiếp tục mua sắm ngay</a>
        </div>
    }
    else
    {
        <p style="color:#777; margin-bottom: 25px;">Bạn đang có <strong>@Model.Sum(x => x.Quantity)</strong> sản phẩm trong giỏ hàng. Vui lòng tick chọn sản phẩm muốn thanh toán.</p>

        <form asp-controller="Cart" asp-action="Checkout" method="post" id="checkoutForm">
            <table class="cart-table">
                <thead>
                    <tr>
                        <th style="width: 50px; text-align: center;">
                            <input type="checkbox" id="selectAll" class="custom-checkbox" onchange="toggleAll(this)" />
                        </th>
                        <th>Sản phẩm</th>
                        <th>Đơn giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                        <th>Xóa</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var item = Model[i];
                        <tr>
                            <td data-label="Chọn" style="text-align: center;">
                                <input type="checkbox" name="selectedItems" value="@item.ProductId" class="custom-checkbox item-checkbox" data-price="@item.Total" onchange="calculateTotal()" />
                            </td>
                            
                            <td data-label="Sản phẩm">
                                <div class="product-info">
                                    <img src="@item.ImageUrl" class="product-img" alt="@item.ProductName" onerror="this.src='https://via.placeholder.com/150'">
                                    <div>
                                        <div class="product-name">@item.ProductName</div>
                                        <div style="font-size: 12px; color: #999;">Velvy Skin</div>
                                    </div>
                                </div>
                            </td>
                            <td data-label="Đơn giá" class="price">@item.Price.ToString("N0")đ</td>
                            
                            <td data-label="Số lượng">
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <a asp-controller="Cart" asp-action="UpdateQuantity" asp-route-id="@item.ProductId" asp-route-quantity="@(item.Quantity - 1)" style="text-decoration: none; background: #eee; width: 25px; height: 25px; display: flex; align-items: center; justify-content: center; border-radius: 5px; color: #333; font-weight: bold;">-</a>
                                    <span style="font-weight: bold; width: 20px; text-align: center;">@item.Quantity</span>
                                    <a asp-controller="Cart" asp-action="UpdateQuantity" asp-route-id="@item.ProductId" asp-route-quantity="@(item.Quantity + 1)" style="text-decoration: none; background: #eee; width: 25px; height: 25px; display: flex; align-items: center; justify-content: center; border-radius: 5px; color: #333; font-weight: bold;">+</a>
                                </div>
                            </td>
                            
                            <td data-label="Thành tiền" class="price">@item.Total.ToString("N0")đ</td>
                            
                            <td data-label="Xóa">
                                <a asp-controller="Cart" asp-action="RemoveFromCart" asp-route-id="@item.ProductId" class="remove-btn" title="Xóa sản phẩm">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="cart-bottom-area">
                <div style="flex: 1;">
                    <a asp-controller="Cart" asp-action="ClearCart" class="btn-clear-cart" onclick="return confirm('Bạn có chắc muốn xóa toàn bộ giỏ hàng không?');">
                        <i class="fa-solid fa-trash-can"></i> Xóa toàn bộ giỏ hàng
                    </a>

                    <div style="background: #fdfdfd; padding: 20px; border-radius: 16px; border: 1px solid #f0f0f0; margin-top: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); max-width: 500px;">
                        <h6 style="font-weight: 700; margin-bottom: 15px; color: var(--dark-mint);">
                            <i class="fa-solid fa-ticket" style="margin-right: 5px;"></i> Khuyến mãi & Ưu đãi
                        </h6>
                        
                        <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                            <input type="text" id="manualCouponCode" placeholder="Nhập mã giảm giá..." style="flex: 1; padding: 10px 15px; border: 1px solid #eee; border-radius: 8px; text-transform: uppercase; outline: none;">
                            <button type="button" onclick="applyCoupon(document.getElementById('manualCouponCode').value)" style="background: var(--text-gray); color: white; border: none; padding: 0 20px; border-radius: 8px; font-weight: 600; cursor: pointer; transition: 0.3s;">Áp dụng</button>
                        </div>

                        <div style="display: flex; align-items: center; gap: 15px;">
                            <hr style="flex: 1; border-color: #eee;">
                            <span style="font-size: 12px; color: #999; font-weight: 600; text-transform: uppercase;">HOẶC</span>
                            <hr style="flex: 1; border-color: #eee;">
                        </div>

                        <button type="button" data-bs-toggle="modal" data-bs-target="#voucherModal" style="width: 100%; margin-top: 15px; background: var(--light-mint); color: var(--dark-mint); border: 1px dashed var(--primary-mint); padding: 12px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: 0.3s; display: flex; justify-content: center; align-items: center; gap: 8px;">
                            <i class="fa-solid fa-list-check"></i> Chọn mã từ Kho Voucher
                        </button>

                        <div id="couponMessage" style="margin-top: 15px; font-size: 13px; font-weight: 600; display: none;"></div>
                    </div>
                </div>

                <div class="cart-summary">
                    <h3>Tóm tắt đơn hàng</h3>
                    <div class="summary-row">
                        <span>Tạm tính (<span id="countSelected">0</span> SP)</span>
                        <span style="font-weight: 600;" id="subTotalDisplay">0đ</span>
                    </div>
                    
                    <div class="summary-row" id="discountRow" style="display: none;">
                        <span>Giảm giá (<span id="appliedCodeText" style="color:var(--primary-mint);font-weight:bold;"></span>)</span>
                        <span id="discountDisplay" style="color: var(--primary-mint); font-weight: bold; font-size: 16px;">-0đ</span>
                    </div>

                    <div class="summary-row">
                        <span>Phí vận chuyển</span>
                        <span id="shippingDisplay">0đ</span>
                    </div>

                    <div class="summary-row summary-total">
                        <span>Tổng cộng</span>
                        <span id="finalTotalDisplay">0đ</span>
                    </div>
                    
                    <button type="submit" class="btn-checkout disabled" id="btnCheckout">
                        Tiến hành thanh toán <i class="fa-solid fa-arrow-right ms-2"></i>
                    </button>
                    <p style="text-align: center; font-size: 12px; color: #888; margin-top: 10px;">Vui lòng chọn ít nhất 1 sản phẩm để thanh toán</p>
                </div>
            </div>
        </form>
    }
</div>

<div class="modal fade" id="voucherModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="border-radius: 20px; border: none;">
            <div class="modal-header" style="background: var(--primary-mint); color: white; padding: 15px 20px; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title" style="font-size: 16px; font-weight: 700;">Chọn Mã Khuyến Mãi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="background: #f8f9fa; padding: 20px;" id="voucherListContainer">
                <p style="text-align: center; color: #888; font-size: 14px;">
                    <i class="fa-solid fa-spinner fa-spin"></i> Đang tải dữ liệu...
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    let currentSubTotal = 0;      // Lưu giữ tổng tiền chưa giảm
    let currentDiscount = 0;      // Số tiền đang được giảm
    let appliedCouponCode = "";   // Tên mã đang xài
    let appliedDiscountType = ""; // 🔥 Biến mới: Lưu loại mã (Percent, Amount, Freeship)

    function formatMoney(amount) {
        return new Intl.NumberFormat('vi-VN').format(amount) + 'đ';
    }

    // ================= CỤM 1: XỬ LÝ CHECKBOX =================
    function toggleAll(source) {
        const checkboxes = document.querySelectorAll('.item-checkbox');
        checkboxes.forEach(cb => { cb.checked = source.checked; });
        calculateTotal();
    }

    function calculateTotal() {
        const checkboxes = document.querySelectorAll('.item-checkbox');
        const btnCheckout = document.getElementById('btnCheckout');
        let newSubTotal = 0;
        let countSelected = 0;

        checkboxes.forEach(cb => {
            if (cb.checked) {
                newSubTotal += parseFloat(cb.getAttribute('data-price'));
                countSelected++;
            }
        });

        currentSubTotal = newSubTotal;
        document.getElementById('countSelected').innerText = countSelected;

        // Bật/Tắt nút Thanh toán
        if (countSelected > 0) {
            btnCheckout.classList.remove('disabled');
        } else {
            btnCheckout.classList.add('disabled');
        }

        const checkAllBox = document.getElementById('selectAll');
        if(checkAllBox) {
            checkAllBox.checked = (countSelected === checkboxes.length) && (checkboxes.length > 0);
        }

        // MỖI KHI ĐỔI CHECKBOX, PHẢI KIỂM TRA LẠI MÃ GIẢM GIÁ
        if (appliedCouponCode !== "" && countSelected > 0) {
            recheckCouponSilent(appliedCouponCode);
        } else {
            removeCouponSilent();
        }

        updateFinalDisplay();
    }

    // Cập nhật giao diện tiền nong tổng thể
    function updateFinalDisplay() {
        let shippingFee = 0;
        // Chỉ tính ship khi có chọn hàng
        if (currentSubTotal > 0 && currentSubTotal < 500000) {
            shippingFee = 30000;
        }

        // 🔥 LOGIC FREESHIP NẰM Ở ĐÂY 🔥
        if (appliedDiscountType === "Freeship") {
            shippingFee = 0; // Xóa sổ phí vận chuyển
            currentDiscount = 0; // Mã freeship thì ko giảm tiền hàng
        } else {
            // Tiền giảm ko đc lớn hơn tổng tiền hàng (chống lỗ vốn)
            if(currentDiscount > currentSubTotal) currentDiscount = currentSubTotal;
        }

        let finalTotal = currentSubTotal - currentDiscount + shippingFee;

        // Hiển thị ra HTML
        document.getElementById('subTotalDisplay').innerText = formatMoney(currentSubTotal);
        
        // Nếu là Freeship thì in chữ cho đẹp
        if (appliedDiscountType === "Freeship" && currentSubTotal > 0) {
            document.getElementById('shippingDisplay').innerHTML = '<span style="color: #2ec4b6; font-weight: bold;">Miễn phí (Áp mã)</span>';
        } else {
            document.getElementById('shippingDisplay').innerText = shippingFee === 0 ? (currentSubTotal > 0 ? "Miễn phí" : "0đ") : formatMoney(shippingFee);
        }

        document.getElementById('finalTotalDisplay').innerText = formatMoney(finalTotal);

        // Hiện/Ẩn dòng Giảm giá hàng hóa
        const discountRow = document.getElementById('discountRow');
        if (currentDiscount > 0 && appliedDiscountType !== "Freeship") {
            discountRow.style.display = 'flex';
            document.getElementById('appliedCodeText').innerText = appliedCouponCode;
            document.getElementById('discountDisplay').innerText = '-' + formatMoney(currentDiscount);
        } else if (appliedDiscountType === "Freeship") {
            // Nếu là freeship thì hiện dòng thông báo mã freeship
            discountRow.style.display = 'flex';
            document.getElementById('appliedCodeText').innerText = appliedCouponCode;
            document.getElementById('discountDisplay').innerText = 'Freeship';
        } else {
            discountRow.style.display = 'none';
        }
    }

    // ================= CỤM 2: XỬ LÝ MÃ KHUYẾN MÃI (AJAX) =================
    function applyCoupon(codeParam) {
        var msgBox = document.getElementById('couponMessage');
        
        if (currentSubTotal <= 0) {
            msgBox.style.display = 'block';
            msgBox.style.color = '#ff4d4d';
            msgBox.innerHTML = '<i class="fa-solid fa-circle-exclamation"></i> Vui lòng tick chọn sản phẩm trước khi áp dụng mã!';
            return;
        }

        if (!codeParam || codeParam.trim() === '') {
            msgBox.style.display = 'block';
            msgBox.style.color = '#ff4d4d';
            msgBox.innerHTML = '<i class="fa-solid fa-circle-exclamation"></i> Vui lòng nhập mã!';
            return;
        }

        $.ajax({
            url: '/Cart/ApplyCoupon',
            type: 'POST',
            data: { code: codeParam }, 
            success: function (res) {
                msgBox.style.display = 'block';
                if (res.success) {
                    currentDiscount = res.discount;
                    appliedCouponCode = codeParam;
                    appliedDiscountType = res.discountType; // 🔥 Nhận loại mã từ C# trả về

                    msgBox.style.color = '#2ec4b6';
                    msgBox.innerHTML = '<i class="fa-solid fa-check-circle"></i> ' + res.message;
                    document.getElementById('manualCouponCode').value = codeParam; 
                    
                    updateFinalDisplay(); 
                } else {
                    removeCouponSilent();
                    msgBox.style.color = '#ff4d4d';
                    msgBox.innerHTML = '<i class="fa-solid fa-circle-exclamation"></i> ' + res.message;
                    updateFinalDisplay();
                }
            }
        });
    }

    // Hàm gọi ngầm để check lại mã khi khách thay đổi checkbox
    function recheckCouponSilent(codeParam) {
        $.ajax({
            url: '/Cart/ApplyCoupon',
            type: 'POST',
            data: { code: codeParam },
            success: function (res) {
                if (res.success) {
                    currentDiscount = res.discount; 
                    appliedDiscountType = res.discountType; // Cập nhật loại
                } else {
                    removeCouponSilent();
                    var msgBox = document.getElementById('couponMessage');
                    msgBox.style.display = 'block';
                    msgBox.style.color = '#ff4d4d';
                    msgBox.innerHTML = '<i class="fa-solid fa-circle-exclamation"></i> ' + res.message;
                }
                updateFinalDisplay();
            }
        });
    }

    // Gỡ mã trong im lặng
    function removeCouponSilent() {
        currentDiscount = 0;
        appliedCouponCode = "";
        appliedDiscountType = ""; // Reset
        document.getElementById('manualCouponCode').value = "";
    }

    // Khởi động
    window.onload = function() {
        calculateTotal();
    };

    // ================= CỤM 3: TẢI DANH SÁCH MÃ VÀO MODAL =================
    $('#voucherModal').on('show.bs.modal', function (e) {
        const container = document.getElementById('voucherListContainer');
        container.innerHTML = '<p style="text-align: center; color: #888; font-size: 14px;"><i class="fa-solid fa-spinner fa-spin"></i> Đang tải dữ liệu...</p>';
        
        $.ajax({
            url: '/Home/GetVoucherListHtml',
            type: 'GET',
            success: function (htmlContent) {
                container.innerHTML = htmlContent;
            },
            error: function () {
                container.innerHTML = '<p style="text-align: center; color: red;">Lỗi tải dữ liệu. Vui lòng thử lại sau.</p>';
            }
        });
    });
</script>
}