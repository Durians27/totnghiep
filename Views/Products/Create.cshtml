@model VelvySkinWeb.Models.Product

@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
}

<div class="container mt-5 mb-5">
    <h2 style="color: var(--primary-mint); font-family: 'Playfair Display';">Thêm Mỹ Phẩm Lên Kệ</h2>
    <hr />
    <div class="row">
        <div class="col-md-8 bg-white p-4 rounded shadow-sm">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Name" class="control-label fw-bold">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Sữa rửa mặt Cetaphil" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Price" class="control-label fw-bold">Giá bán (VNĐ)</label>
                        <input asp-for="Price" type="number" class="form-control" placeholder="VD: 250000" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="CategoryId" class="control-label fw-bold">Thuộc danh mục nào?</label>
                        <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                    </div>
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="StockQuantity" class="control-label fw-bold">Số lượng nhập kho</label>
                        <input asp-for="StockQuantity" type="number" class="form-control" value="100" />
                        <span asp-validation-for="StockQuantity" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ImageFile" class="control-label fw-bold">Tải ảnh sản phẩm lên</label>
                    <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" required />
                    <small class="text-muted">Vui lòng chọn ảnh định dạng JPG, PNG.</small>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Description" class="control-label fw-bold">Mô tả chi tiết</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập công dụng, thành phần của mỹ phẩm..."></textarea>
                </div>

                <div class="form-group">
                    <input type="submit" value="Lưu Sản Phẩm" class="btn btn-lg w-100 mb-2" style="background-color: var(--primary-mint); color: white; font-weight: bold;" />
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Hủy và quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}