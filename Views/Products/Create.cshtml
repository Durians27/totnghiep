@model VelvySkinWeb.Models.Product

@{
    ViewData["Title"] = "Thêm Sản phẩm";
}

<div class="container mt-5">
    <h2 style="color: var(--velvy-primary);">Thêm Mỹ Phẩm Lên Kệ</h2>
    <hr />
    <div class="row">
        <div class="col-md-8 bg-white p-4 rounded shadow-sm">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Name" class="control-label fw-bold">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Sữa rửa mặt Cetaphil" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Price" class="control-label fw-bold">Giá bán (VNĐ)</label>
                        <input asp-for="Price" type="number" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CategoryId" class="control-label fw-bold">Thuộc Danh mục nào?</label>
                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ImageFile" class="control-label fw-bold">Tải ảnh sản phẩm lên</label>
                    <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Description" class="control-label fw-bold">Mô tả chi tiết</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input type="submit" value="Lưu Sản Phẩm" class="btn btn-velvy btn-lg w-100" />
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}