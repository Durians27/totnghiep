@model VelvySkinWeb.Models.Coupon
@{
    ViewData["Title"] = "Tạo Mã Khuyến Mãi Mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --primary-mint: #2ec4b6;
        --dark-mint: #208b81;
        --light-mint: #f0fdfa;
        --bg-gray: #f8f9fa;
        --danger: #ff4d4d;
    }


    .coupon-create-wrapper { max-width: 900px; margin: 0 auto; background: white; padding: 40px; border-radius: 30px; box-shadow: 0 20px 50px rgba(0,0,0,0.05); }

    .page-header { margin-bottom: 30px; border-bottom: 1px solid #f0f0f0; padding-bottom: 20px; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 28px; color: var(--dark-mint); margin: 0; }
    .page-subtitle { color: #888; font-size: 14px; margin-top: 5px; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 25px; }
    .full-width { grid-column: span 2; }

    .input-group { display: flex; flex-direction: column; gap: 8px; }
    .input-group label { font-weight: 700; font-size: 13px; color: var(--dark-mint); text-transform: uppercase; letter-spacing: 0.5px; }
    
    input, select, textarea {
        padding: 12px 15px; border: 1px solid #eee; border-radius: 12px; font-family: inherit; outline: none; transition: 0.3s; width: 100%; box-sizing: border-box;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--primary-mint); box-shadow: 0 0 0 3px rgba(46, 196, 182, 0.1); }

    .code-input-wrapper { position: relative; display: flex; gap: 10px; }
    .code-input-wrapper input { flex: 1; font-family: 'monospace'; font-weight: 700; color: var(--primary-mint); letter-spacing: 1px; }
    .btn-generate { background: var(--light-mint); color: var(--primary-mint); border: 1px dashed var(--primary-mint); padding: 0 15px; border-radius: 10px; cursor: pointer; font-weight: 600; font-size: 12px; transition: 0.3s;}
    .btn-generate:hover { background: var(--primary-mint); color: white; }

    .actions { margin-top: 40px; display: flex; justify-content: flex-end; gap: 15px; padding-top: 25px; border-top: 1px solid #f0f0f0; }
    .btn { padding: 12px 30px; border-radius: 12px; font-weight: 700; cursor: pointer; border: none; transition: 0.3s; font-family: inherit; text-decoration: none;}
    .btn-cancel { background: #eee; color: #666; }
    .btn-save { background: var(--primary-mint); color: white; box-shadow: 0 10px 20px rgba(46, 196, 182, 0.2); }
    .btn-save:hover { background: var(--dark-mint); transform: translateY(-2px); }

    .text-danger { color: var(--danger); font-size: 12px; font-weight: 600; margin-top: 5px; display: block;}
    
    @@media (max-width: 768px) { .form-grid { grid-template-columns: 1fr; } .full-width { grid-column: span 1; } }
</style>

<div class="coupon-create-wrapper">
    <div class="page-header">
        <h1 class="page-title">Tạo Mã Khuyến Mãi</h1>
        <p class="page-subtitle">Thiết lập chương trình ưu đãi mới cho khách hàng Velvy Skin</p>
    </div>

    <form asp-action="Create" method="post">
        
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-grid">
            <div class="input-group full-width">
                <label>Tên chiến dịch *</label>
                <input asp-for="Name" placeholder="Ví dụ: Chào Hè Rực Rỡ 2026" required>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="input-group">
                <label>Mã khuyến mãi (Code) *</label>
                <div class="code-input-wrapper">
                    <input asp-for="Code" id="couponCode" placeholder="VELVYSUMMER" style="text-transform: uppercase;" required>
                    <button type="button" class="btn-generate" onclick="generateCode()">Tạo mã tự động</button>
                </div>
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="input-group">
                <label>Loại giảm giá</label>
                <select asp-for="DiscountType">
                    <option value="Percent">Giảm theo phần trăm (%)</option>
                    <option value="Amount">Giảm số tiền cố định (đ)</option>
                    <option value="Freeship">Miễn phí vận chuyển</option>
                </select>
            </div>

            <div class="input-group">
                <label>Giá trị giảm *</label>
                <input asp-for="DiscountValue" type="number" placeholder="Ví dụ: 20 hoặc 50000" required>
            </div>
<div class="input-group">
                <label>Giảm tối đa (đ) <span style="font-weight: 400; color: #888;">(Dành cho mã %)</span></label>
                <input asp-for="MaxDiscountAmount" type="number" value="0" placeholder="Nhập 0 = Không giới hạn">
            </div>
            <div class="input-group">
                <label>Áp dụng cho đơn từ (đ)</label>
                <input asp-for="MinOrderValue" type="number" value="0" placeholder="Nhập 0 = Áp dụng mọi đơn">
            </div>

            <div class="input-group">
                <label>Tổng lượt sử dụng tối đa</label>
                <input asp-for="MaxUses" type="number" value="0" placeholder="Nhập 0 = Không giới hạn">
            </div>

            <div class="input-group">
                <label>Ngày bắt đầu</label>
                <input asp-for="StartDate" type="date" required>
            </div>

            <div class="input-group">
                <label>Ngày kết thúc</label>
                <input asp-for="EndDate" type="date" required>
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="input-group full-width">
                <label>Lượt dùng mỗi khách hàng</label>
                <input asp-for="MaxUsesPerUser" type="number" value="1" min="1" style="width: 50%;">
            </div>

            <div class="input-group full-width">
                <label>Mô tả chi tiết / Điều kiện áp dụng</label>
                <textarea asp-for="Description" rows="4" placeholder="Nhập các điều kiện như: Chỉ áp dụng cho Serum, Không áp dụng với combo..."></textarea>
            </div>
        </div>

        <div class="actions">
            <a asp-action="Index" class="btn btn-cancel">Hủy bỏ</a>
            <button type="submit" class="btn btn-save"><i class="fa-solid fa-check"></i> Kích hoạt mã</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
 
        function generateCode() {
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
            let result = '';
            for (let i = 0; i < 5; i++) {
                result += chars.charAt(Math.floor(Math.random() * chars.length));
            }
      
            document.getElementById('couponCode').value = 'VELVY' + result;
        }

        document.addEventListener("DOMContentLoaded", function() {
            let today = new Date();
            let nextMonth = new Date();
            nextMonth.setDate(today.getDate() + 30);

            document.getElementById('StartDate').valueAsDate = today;
            document.getElementById('EndDate').valueAsDate = nextMonth;
        });
    </script>
}