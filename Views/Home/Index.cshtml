@{
    ViewData["Title"] = "Trang chủ";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">

<style>
    body {
        background-color: #FAFAF8 !important; /* Màu nền web trắng ngà */
    }

    /* KHU VỰC BANNER MÀU DA DỊU NHẸ */
    .premium-hero {
        background-color: #F3E8E0; /* Màu Nude / Da dịu cực kỳ sang */
        border-radius: 16px; /* Bo góc hình chữ nhật vừa phải */
        padding: 5rem 4rem;
        margin-top: 2rem;
        color: #4A3C31; /* Chữ màu nâu trầm trầm, không dùng màu đen */
        position: relative;
        box-shadow: 0 15px 35px rgba(212, 163, 115, 0.1);
        display: flex;
        align-items: center;
    }

    /* PHÔNG CHỮ TIÊU ĐỀ */
    .serif-heading {
        font-family: 'Playfair Display', serif;
        font-size: 4.8rem;
        line-height: 1.15;
        font-weight: 700;
        margin-bottom: 1.5rem;
        letter-spacing: -1px;
        color: #3D2B1F;
    }

    .sans-text {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.15rem;
        font-weight: 400;
        color: #5C4D43;
        max-width: 480px;
        line-height: 1.7;
        margin-bottom: 2.5rem;
    }

    /* NÚT BẤM CHỮ NHẬT HOA MỸ & SANG TRỌNG */
    .elegant-btn {
        display: inline-block;
        background-color: #C08D5D; /* Màu nâu caramel của Velvy Skin */
        color: white !important;
        padding: 16px 40px;
        border-radius: 6px; /* Chữ nhật bo góc rất nhẹ */
        font-family: 'DM Sans', sans-serif;
        font-weight: 500;
        font-size: 1.1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(192, 141, 93, 0.25);
        letter-spacing: 0.5px;
    }

    .elegant-btn:hover {
        background-color: #A8784C;
        transform: translateY(-3px);
        box-shadow: 0 12px 25px rgba(192, 141, 93, 0.35);
    }

  
    /* KHU VỰC ELEVATE DƯỚI BANNER */
    .elevate-section {
        margin-top: 6rem;
        padding-bottom: 4rem;
    }

    .elevate-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.2rem;
        color: #3D2B1F;
        font-weight: 700;
        line-height: 1.2;
    }

    .elevate-subtitle {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.15rem;
        color: #666;
        margin-top: 1.5rem;
        line-height: 1.6;
    }

    .product-card-mini {
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        display: flex;
        align-items: center;
        gap: 20px;
        border: 1px solid #F0EBE1;
    }

    .mini-img-placeholder {
        width: 80px;
        height: 100px;
        background-color: #F3E8E0;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        color: #A89C92;
        text-align: center;
    }
</style>

<div class="premium-hero">
    <div class="row w-100 align-items-center">
        
        <div class="col-lg-7">
            <div style="background: rgba(255,255,255,0.4); display: inline-block; padding: 6px 18px; border-radius: 4px; margin-bottom: 25px; font-family: 'DM Sans'; font-size: 0.9rem; color: #5C4D43; border: 1px solid rgba(0,0,0,0.05);">
                ✨ Chăm sóc da chuẩn chuyên gia
            </div>
            
            <h1 class="serif-heading">Vẻ đẹp bắt nguồn<br>từ sự thấu hiểu.</h1>
            <p class="sans-text">
                Không có làn da nào giống nhau. Hệ thống AI của Velvy Skin sẽ lắng nghe, phân tích và đề xuất lộ trình chăm sóc độc bản dành riêng cho bạn.
            </p>

            <a asp-controller="SkinTest" asp-action="Index" class="elegant-btn">
                Khám Phá Phác Đồ Làn Da
            </a>
        </div>

        <div class="col-lg-5">
            <div class="rect-placeholder">
                <img src="~/images/banner-chinh.jpg" alt="Velvy Skin Chăm Sóc Da" style="width: 100%; height: 500px; object-fit: cover; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);" />
            </div>
        </div>
        
    </div>
</div>

<div class="elevate-section row align-items-center">
    <div class="col-lg-6">
        <h2 class="elevate-title">Nâng Tầm Trải Nghiệm<br>Skincare</h2>
        <p class="elevate-subtitle">
            Đừng để làn da phải chịu đựng những sản phẩm sai lệch. Hãy thiết lập một thói quen làm sạch, cấp ẩm và bảo vệ được thiết kế cho chính bạn.
        </p>
    </div>

    <div class="col-lg-5 offset-lg-1 mt-4 mt-lg-0">
        <div class="product-card-mini">
            <div class="mini-img-placeholder">Ảnh SP</div>
            <div>
                <h4 style="font-family: 'Playfair Display'; font-weight: 700; margin: 0; color: #3D2B1F;">Velvy Pure Serum</h4>
                <p style="font-family: 'DM Sans'; color: #666; font-size: 0.9rem; margin-top: 5px; margin-bottom: 10px;">Tinh chất phục hồi sâu</p>
                <a asp-controller="Product" asp-action="Index" style="color: #C08D5D; font-weight: 700; text-decoration: none; font-family: 'DM Sans'; font-size: 0.9rem;">Xem chi tiết ➔</a>
            </div>
        </div>
    </div>
</div>