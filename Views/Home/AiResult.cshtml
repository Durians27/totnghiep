@model IEnumerable<VelvySkinWeb.Models.Product>
@{ ViewData["Title"] = "Kết Quả Phân Tích"; }

<style>
    .result-wrapper { padding: 60px 5%; background: linear-gradient(180deg, #f0fdfc 0%, #ffffff 100%); }
    .main-card { max-width: 950px; margin: 0 auto; background: var(--white); border-radius: 30px; box-shadow: 0 20px 60px rgba(0,0,0,0.05); padding: 50px; }

    /* === CIRCULAR PROGRESS === */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin: 40px 0; }
    .stat-item { border: 1px solid #f0f0f0; border-radius: 20px; padding: 25px; text-align: center; transition: 0.3s; }
    .stat-item:hover { border-color: var(--primary-mint); transform: translateY(-5px); }
    .stat-item h4 { margin-top: 12px; font-size: 15px; color: #555; font-weight: 600; }

    .circle-wrap { position: relative; width: 90px; height: 90px; margin: 0 auto; }
    .circle-wrap svg { transform: rotate(-90deg); }
    .circle-bg { fill: none; stroke: #e8f5f4; stroke-width: 8; }
    .circle-progress { fill: none; stroke: var(--primary-mint); stroke-width: 8; stroke-linecap: round;
        stroke-dasharray: 226; stroke-dashoffset: 226; transition: stroke-dashoffset 1.5s ease; }
    .circle-label { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
        font-size: 18px; font-weight: 700; color: var(--primary-mint); }

    /* màu riêng cho từng chỉ số */
    .stat-oil      .circle-progress { stroke: #f4a261; }
    .stat-oil      .circle-label    { color: #f4a261; }
    .stat-acne     .circle-progress { stroke: #e76f51; }
    .stat-acne     .circle-label    { color: #e76f51; }
    .stat-smooth   .circle-progress { stroke: #2ec4b6; }
    .stat-smooth   .circle-label    { color: #2ec4b6; }

    /* === AI COMMENT === */
    .ai-comment-section { background: #f0fdfc; border-left: 4px solid var(--primary-mint);
        border-radius: 12px; padding: 20px 25px; margin: 10px 0 30px; }
    .ai-comment-section h4 { font-size: 17px; font-weight: 700; margin-bottom: 10px; color: var(--dark-mint); }
    .ai-comment-section p { color: #444; line-height: 1.7; margin: 0; }

    /* === PRODUCTS === */
    .routine-box { background: #f9fefe; border-radius: 25px; padding: 35px; margin-top: 40px; }
    .section-title { font-size: 24px; font-weight: 700; color: var(--dark-mint); margin-bottom: 25px; display: flex; align-items: center; gap: 12px; }
    .product-suggestions { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 20px; }
    .mini-card { background: white; border-radius: 15px; padding: 15px; display: flex; align-items: flex-start; gap: 15px;
        transition: 0.3s; cursor: pointer; border: 1px solid transparent; text-decoration: none; color: inherit; flex-direction: column; }
    .mini-card:hover { border-color: var(--primary-mint); box-shadow: 0 8px 15px rgba(0,0,0,0.06); }
    .mini-card img { width: 100%; height: 130px; object-fit: cover; border-radius: 10px; background: #f9f9f9; }
    .mini-info { width: 100%; }
    .mini-info h5 { font-size: 14px; color: #333; margin-bottom: 4px; font-weight: 600; line-height: 1.4; }
    .mini-info .price { font-weight: 700; color: var(--primary-mint); font-size: 14px; }
    .step-tag { font-size: 10px; background: var(--light-mint); color: var(--dark-mint);
        padding: 2px 8px; border-radius: 10px; font-weight: 600; text-transform: uppercase; display: inline-block; margin-bottom: 6px; }
    .reason-tag { font-size: 11px; color: #888; margin-top: 5px; font-style: italic; line-height: 1.4; }

    .btn-buy-all { background: var(--accent-pink); color: white; border: none; padding: 18px 45px;
        border-radius: 50px; font-size: 18px; font-weight: 700; cursor: pointer; transition: 0.3s;
        box-shadow: 0 10px 20px rgba(233, 147, 176, 0.3); display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
    .btn-buy-all:hover { transform: scale(1.05); background: #d87d9a; color: white; }
</style>

<div class="result-wrapper">
    <div class="main-card">

        <div style="text-align: center; margin-bottom: 40px;">
            <h1 style="font-family: 'Playfair Display', serif; font-size: 38px; color: var(--dark-mint);">Kết Quả Phân Tích Da</h1>
            <p>AI đã hoàn tất việc quét. Dưới đây là các chỉ số sức khỏe da của bạn.</p>
        </div>

        <!-- 4 CHỈ SỐ VÒNG TRÒN -->
        <div class="stats-grid">
            <div class="stat-item stat-moisture">
                <div class="circle-wrap">
                    <svg width="90" height="90" viewBox="0 0 90 90">
                        <circle class="circle-bg" cx="45" cy="45" r="36"/>
                        <circle class="circle-progress" id="prog-moisture" cx="45" cy="45" r="36"/>
                    </svg>
                    <div class="circle-label" id="lbl-moisture">0%</div>
                </div>
                <h4>Độ ẩm</h4>
            </div>
            <div class="stat-item stat-oil">
                <div class="circle-wrap">
                    <svg width="90" height="90" viewBox="0 0 90 90">
                        <circle class="circle-bg" cx="45" cy="45" r="36"/>
                        <circle class="circle-progress" id="prog-oil" cx="45" cy="45" r="36"/>
                    </svg>
                    <div class="circle-label" id="lbl-oil">0%</div>
                </div>
                <h4>Độ dầu</h4>
            </div>
            <div class="stat-item stat-acne">
                <div class="circle-wrap">
                    <svg width="90" height="90" viewBox="0 0 90 90">
                        <circle class="circle-bg" cx="45" cy="45" r="36"/>
                        <circle class="circle-progress" id="prog-acne" cx="45" cy="45" r="36"/>
                    </svg>
                    <div class="circle-label" id="lbl-acne">0%</div>
                </div>
                <h4>Mụn/Thâm</h4>
            </div>
            <div class="stat-item stat-smooth">
                <div class="circle-wrap">
                    <svg width="90" height="90" viewBox="0 0 90 90">
                        <circle class="circle-bg" cx="45" cy="45" r="36"/>
                        <circle class="circle-progress" id="prog-smooth" cx="45" cy="45" r="36"/>
                    </svg>
                    <div class="circle-label" id="lbl-smooth">0%</div>
                </div>
                <h4>Độ mịn</h4>
            </div>
        </div>

        <!-- NHẬN ĐỊNH AI -->
        <div class="ai-comment-section">
            <h4><i class="fa-solid fa-robot"></i> Nhận định từ AI</h4>
            <p>@ViewBag.AiAdvice</p>
        </div>

        <!-- SẢN PHẨM GỢI Ý -->
        <div class="routine-box">
            <h2 class="section-title"><i class="fa-solid fa-wand-magic-sparkles"></i> Lộ trình chăm sóc đề xuất</h2>

            <div class="product-suggestions">
                @{
                    int stepCount = 1;
                    var reasons = ViewBag.SuggestedReasons as List<string> ?? new List<string>();
                }
                @foreach (var item in Model)
                {
                    string reason = (stepCount - 1 < reasons.Count) ? reasons[stepCount - 1] : "";
                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="mini-card">
                        <img src="@item.ImageUrl" alt="@item.Name" onerror="this.src='https://via.placeholder.com/220x130?text=No+Image'">
                        <div class="mini-info">
                            <span class="step-tag">Gợi ý @stepCount</span>
                            <h5>@item.Name</h5>
                            @if (item.DiscountPrice > 0 && item.DiscountPrice < item.Price)
                            {
                                <p class="price">@item.DiscountPrice.ToString("N0")đ <small style="text-decoration:line-through;color:#aaa;font-weight:400">@item.Price.ToString("N0")đ</small></p>
                            }
                            else
                            {
                                <p class="price">@item.Price.ToString("N0")đ</p>
                            }
                            @if (!string.IsNullOrEmpty(reason))
                            {
                                <p class="reason-tag"><i class="fa-solid fa-circle-check" style="color:var(--primary-mint)"></i> @reason</p>
                            }
                        </div>
                    </a>
                    stepCount++;
                }
            </div>

            <div style="text-align: center; margin-top: 40px;">
                <form asp-controller="Cart" asp-action="AddRoutineToCart" method="post">
                    @if (Model != null)
                    {
                        foreach (var item in Model)
                        {
                            <input type="hidden" name="productIds" value="@item.Id" />
                        }
                    }
                    <button type="submit" class="btn-buy-all">
                        <i class="fa-solid fa-cart-plus"></i> Thêm tất cả vào giỏ hàng
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    // Dữ liệu từ C# — dùng Smoothness (không phải Smooth)
    const scores = {
        moisture  : @ViewBag.Moisture,
        oil       : @ViewBag.Oil,
        acne      : @ViewBag.Acne,
        smoothness: @ViewBag.Smoothness
    };

    // Chu vi vòng tròn r=36 → C = 2π×36 ≈ 226.2
    const CIRCUMFERENCE = 2 * Math.PI * 36;

    function animateCircle(progId, lblId, targetPct, duration) {
        const prog = document.getElementById(progId);
        const lbl  = document.getElementById(lblId);
        if (!prog || !lbl) return;

        let current = 0;
        const steps = duration / 16; // ~60fps
        const increment = targetPct / steps;

        const timer = setInterval(() => {
            current += increment;
            if (current >= targetPct) { current = targetPct; clearInterval(timer); }

            // stroke-dashoffset: 226 = 0%, 0 = 100%
            const offset = CIRCUMFERENCE - (current / 100) * CIRCUMFERENCE;
            prog.style.strokeDashoffset = offset;
            lbl.textContent = Math.round(current) + '%';
        }, 16);
    }

    window.addEventListener('load', () => {
        animateCircle('prog-moisture', 'lbl-moisture', scores.moisture,   1400);
        animateCircle('prog-oil',      'lbl-oil',      scores.oil,        1400);
        animateCircle('prog-acne',     'lbl-acne',     scores.acne,       1400);
        animateCircle('prog-smooth',   'lbl-smooth',   scores.smoothness, 1400);
    });
</script>
}
