@model IEnumerable<VelvySkinWeb.Models.Product>
@{ ViewData["Title"] = "Kết Quả Phân Tích"; }

<style>
    /* CSS KẾT QUẢ CỦA NHƯ */
    .result-wrapper { padding: 60px 5%; background: linear-gradient(180deg, #f0fdfc 0%, #ffffff 100%); }
    .main-card { max-width: 950px; margin: 0 auto; background: var(--white); border-radius: 30px; box-shadow: 0 20px 60px rgba(0,0,0,0.05); padding: 50px; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin: 40px 0; }
    .stat-item { border: 1px solid #f0f0f0; border-radius: 20px; padding: 25px; text-align: center; transition: 0.3s; }
    .stat-item:hover { border-color: var(--primary-mint); transform: translateY(-5px); }
    .circle { width: 85px; height: 85px; border-radius: 50%; border: 6px solid #e0f2f1; margin: 0 auto 15px; display: flex; align-items: center; justify-content: center; font-weight: 700; color: var(--primary-mint); border-top-color: var(--primary-mint); font-size: 22px; }
    .routine-box { background: #f0fdfc; border-radius: 25px; padding: 35px; margin-top: 40px; }
    .section-title { font-size: 24px; font-weight: 700; color: var(--dark-mint); margin-bottom: 25px; display: flex; align-items: center; gap: 12px; }
    .product-suggestions { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 20px; }
    .mini-card { background: white; border-radius: 15px; padding: 15px; display: flex; align-items: center; gap: 15px; transition: 0.3s; cursor: pointer; border: 1px solid transparent; text-decoration: none; color: inherit; }
    .mini-card:hover { border-color: var(--primary-mint); box-shadow: 0 8px 15px rgba(0,0,0,0.05); }
    .mini-card img { width: 70px; height: 70px; object-fit: cover; border-radius: 10px; background: #f9f9f9; }
    .mini-info h5 { font-size: 14px; color: var(--text-gray); margin-bottom: 4px; }
    .mini-info .price { font-weight: 700; color: var(--primary-mint); font-size: 14px; }
    .mini-info .step-tag { font-size: 10px; background: var(--light-mint); color: var(--dark-mint); padding: 2px 8px; border-radius: 10px; font-weight: 600; text-transform: uppercase; }
    .btn-buy-all { background: var(--accent-pink); color: white; border: none; padding: 18px 45px; border-radius: 50px; font-size: 18px; font-weight: 700; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 20px rgba(233, 147, 176, 0.3); display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
    .btn-buy-all:hover { transform: scale(1.05); background: #d87d9a; color: white;}
</style>

<div class="result-wrapper">
    <div class="main-card">
        <div style="text-align: center; margin-bottom: 40px;">
            <h1 style="font-family: 'Playfair Display', serif; font-size: 38px; color: var(--dark-mint);">Kết Quả Phân Tích Da ✨</h1>
            <p>AI đã hoàn tất việc quét. Dưới đây là các chỉ số sức khỏe da của bạn.</p>
        </div>

        <div class="stats-grid">
            <div class="stat-item"><div class="circle" id="moisture">0%</div><h4>Độ ẩm 💧</h4></div>
            <div class="stat-item"><div class="circle" id="oil">0%</div><h4>Độ dầu 🛢️</h4></div>
            <div class="stat-item"><div class="circle" id="acne">0%</div><h4>Mụn/Thâm 🌋</h4></div>
            <div class="stat-item"><div class="circle" id="smooth">0%</div><h4>Độ mịn ✨</h4></div>
        </div>

        <div class="diagnosis" style="margin-bottom: 40px;">
            <h2 class="section-title"><i class="fa-solid fa-brain"></i> Nhận định từ AI</h2>
            <p>@Html.Raw(ViewBag.Diagnosis)</p> </div>

        <div class="routine-box">
            <h2 class="section-title"><i class="fa-solid fa-wand-magic-sparkles"></i> Lộ trình chăm sóc đề xuất</h2>
            
            <div class="product-suggestions">
                @{ int stepCount = 1; }
                @foreach(var item in Model)
                {
                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id" class="mini-card">
                        <img src="@item.ImageUrl" alt="@item.Name" onerror="this.src='https://via.placeholder.com/70'">
                        <div class="mini-info">
                            <span class="step-tag">Gợi ý @stepCount</span>
                            <h5>@item.Name</h5>
                            <p class="price">@item.Price.ToString("N0")đ</p>
                        </div>
                    </a>
                    stepCount++;
                }
            </div>

            <div style="text-align: center; margin-top: 40px;">
                <a asp-controller="Cart" asp-action="Index" class="btn-buy-all">
                    <i class="fa-solid fa-cart-plus"></i> Vào giỏ hàng kiểm tra
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hiệu ứng số chạy nhận từ C# Backend
        function animateNumber(id, target, duration) {
            let start = 0;
            let step = target / (duration / 10);
            let el = document.getElementById(id);
            let timer = setInterval(() => {
                start += step;
                if (start >= target) {
                    el.innerText = target + "%";
                    clearInterval(timer);
                } else {
                    el.innerText = Math.floor(start) + "%";
                }
            }, 10);
        }

        window.onload = () => {
            // Truyền biến C# vào biến JS
            animateNumber('moisture', @ViewBag.Moisture, 1500);
            animateNumber('oil', @ViewBag.Oil, 1500);
            animateNumber('acne', @ViewBag.Acne, 1500);
            animateNumber('smooth', @ViewBag.Smooth, 1500);
        };
    </script>
}