@model IEnumerable<VelvySkinWeb.Models.Coupon>
@{
    ViewData["Title"] = "Kho Mã Giảm Giá";
}

<style>
    .voucher-container { max-width: 1100px; margin: 40px auto 80px; padding: 0 5%; }

    /* Tiêu đề trang phong cách Playfair */
    .page-header { text-align: center; margin-bottom: 50px; }
    .page-header h1 { 
        font-family: 'Playfair Display', serif; 
        font-size: 42px; 
        color: #333;
        margin-bottom: 15px;
    }
    .page-header p { color: #888; font-size: 14px; text-transform: uppercase; letter-spacing: 2px; }

    /* Lưới hiển thị mã */
    .coupon-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(450px, 1fr)); 
        gap: 30px; 
    }

    /* Card mã giảm giá thiết kế dạng vé */
    .coupon-card {
        background: var(--white);
        display: flex;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid #f0f0f0;
        transition: var(--transition);
        position: relative;
    }
    .coupon-card:hover { transform: translateY(-8px); box-shadow: 0 15px 40px rgba(0,0,0,0.1); }

    /* Phần bên trái (Giá trị giảm) */
    .coupon-left {
        width: 150px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px;
        text-align: center;
        position: relative;
        color: white;
    }
    /* Hiệu ứng răng cưa */
    .coupon-left::before {
        content: "";
        position: absolute;
        right: -6px; top: 0; bottom: 0;
        width: 12px;
        background-image: radial-gradient(circle at 12px 10px, transparent 0, transparent 6px, var(--white) 6px, var(--white) 12px);
        background-size: 12px 20px;
        z-index: 2;
    }

    .coupon-left i { font-size: 28px; margin-bottom: 10px; opacity: 0.9; }
    .coupon-left .amount { font-size: 30px; font-weight: 700; font-family: 'Playfair Display', serif; line-height: 1.1;}
    .coupon-left .unit { font-size: 12px; font-weight: 600; text-transform: uppercase; margin-top: 5px;}

    /* Phần bên phải (Nội dung) */
    .coupon-right { flex: 1; padding: 25px; display: flex; flex-direction: column; justify-content: space-between; }
    
    .coupon-info h3 { font-size: 18px; color: #333; margin-bottom: 8px; font-weight: 700;}
    .coupon-info p { font-size: 13px; color: #666; margin-bottom: 15px; line-height: 1.5; white-space: pre-line;}

    .coupon-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 15px;
        border-top: 1px dashed #eee;
    }
    .expiry-date { font-size: 12px; color: #ff4d4d; font-weight: 600; }

    /* Nút copy mã */
    .copy-btn {
        background: var(--light-mint);
        color: var(--dark-mint);
        border: none;
        padding: 10px 18px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .copy-btn:hover { background: var(--primary-mint); color: white; }
    .copy-btn i { font-size: 14px; }

    /* Responsive */
    @@media (max-width: 768px) {
        .coupon-grid { grid-template-columns: 1fr; }
        .coupon-card { flex-direction: column; }
        .coupon-left { width: 100%; padding: 30px; flex-direction: row; gap: 15px; }
        .coupon-left::before { display: none; }
        .coupon-left::after {
            content: "";
            position: absolute;
            bottom: -6px; left: 0; right: 0;
            height: 12px;
            background-image: radial-gradient(circle at 10px 12px, transparent 0, transparent 6px, var(--white) 6px, var(--white) 12px);
            background-size: 20px 12px;
        }
    }
</style>

<div class="voucher-container">
    <div class="page-header">
        <p>Velvy Skin Rewards</p>
        <h1>Ưu đãi dành riêng cho bạn</h1>
    </div>

    <div class="coupon-grid">
        @if (!Model.Any())
        {
            <div style="grid-column: 1 / -1; text-align: center; padding: 60px 20px; background: white; border-radius: 20px; border: 1px dashed #ddd;">
                <i class="fa-solid fa-box-open" style="font-size: 50px; color: #ccc; margin-bottom: 15px;"></i>
                <h3 style="color: #666;">Hiện tại chưa có mã khuyến mãi nào.</h3>
                <p style="color: #999;">Hãy quay lại sau nhé!</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {

                string bgColor = "var(--primary-mint)";
                string iconClass = "fa-gift";
                string amountText = "";
                string unitText = "";

                if (item.DiscountType == "Percent")
                {
                    bgColor = "var(--primary-mint)"; // Xanh mint
                    iconClass = "fa-percent";
                    amountText = item.DiscountValue.ToString() + "%";
                    unitText = "Giảm giá";
                }
                else if (item.DiscountType == "Amount")
                {
                    bgColor = "#d4a373"; // Vàng đồng
                    iconClass = "fa-tags";

                    amountText = (item.DiscountValue / 1000).ToString("0") + "K";
                    unitText = "Tiền mặt";
                }
                else if (item.DiscountType == "Freeship")
                {
                    bgColor = "var(--accent-pink)"; // Hồng
                    iconClass = "fa-truck-fast";
                    amountText = "FREE";
                    unitText = "Vận chuyển";
                }


                string condition = "";
                if (item.MinOrderValue > 0) condition += $"Áp dụng cho đơn từ {item.MinOrderValue:N0}đ. ";
                if (item.DiscountType == "Percent" && item.MaxDiscountAmount > 0) condition += $"Giảm tối đa {item.MaxDiscountAmount:N0}đ. ";

                <div class="coupon-card">
                    <div class="coupon-left" style="background: @bgColor;">
                        <i class="fa-solid @iconClass"></i>
                        <div class="amount">@amountText</div>
                        <div class="unit">@unitText</div>
                    </div>
                    <div class="coupon-right">
                        <div class="coupon-info">
                            <h3>@item.Name</h3>
                            <p>
                                <strong style="color: var(--primary-mint);">@condition</strong><br/>
                                @item.Description
                            </p>
                        </div>
                        <div class="coupon-footer">
                            <span class="expiry-date"><i class="fa-regular fa-clock"></i> HSD: @item.EndDate.ToString("dd/MM/yyyy")</span>
                            <button class="copy-btn" onclick="copyCoupon('@item.Code', this)">
                                <i class="fa-regular fa-copy"></i> @item.Code
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        function copyCoupon(code, btn) {

            navigator.clipboard.writeText(code).then(() => {
                const originalContent = btn.innerHTML;
                

                btn.innerHTML = '<i class="fa-solid fa-check"></i> ĐÃ SAO CHÉP';
                btn.style.background = '#208b81';
                btn.style.color = 'white';
                

                setTimeout(() => {
                    btn.innerHTML = originalContent;
                    btn.style.background = '';
                    btn.style.color = '';
                }, 2000);
            });
        }
    </script>
}