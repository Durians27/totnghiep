@{
    ViewData["Title"] = "Tư Vấn Da AI";
}

<style>
    /* BẠN GIỮ NGUYÊN TOÀN BỘ CSS CŨ Ở ĐÂY NHÉ, TÔI KHÔNG GHI LẠI ĐỂ ĐỠ DÀI */
    /* ... (Copy CSS từ file AiConsultation.cshtml cũ dán vào đây) ... */
    .ai-wrapper { flex: 1; padding: 60px 5%; background: linear-gradient(180deg, #f0fdfc 0%, #ffffff 100%); display: flex; flex-direction: column; align-items: center; }
    .ai-intro { text-align: center; max-width: 800px; margin-bottom: 50px; }
    .ai-intro h1 { font-family: 'Playfair Display', serif; font-size: 42px; margin-bottom: 15px; color: #333; }
    .ai-intro p { color: #666; font-size: 16px; line-height: 1.6; }
    .quiz-container { background: var(--white); width: 100%; max-width: 900px; border-radius: 30px; box-shadow: 0 30px 60px rgba(0,0,0,0.08); padding: 50px; position: relative; overflow: hidden; }
    .progress-bar { position: absolute; top: 0; left: 0; width: 100%; height: 6px; background: #eee; }
    .progress-fill { height: 100%; background: var(--primary-mint); width: 33.33%; transition: 0.5s ease; }
    .step { display: none; animation: fadeIn 0.5s ease; }
    .step.active { display: block; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .step-title { font-size: 22px; font-weight: 700; margin-bottom: 30px; text-align: center; color: var(--dark-mint); }
    .options-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .option-card { border: 2px solid #f0f0f0; border-radius: 20px; padding: 30px 20px; text-align: center; cursor: pointer; transition: var(--transition); background: #fff; }
    .option-card i { font-size: 40px; color: var(--primary-mint); margin-bottom: 15px; display: block; }
    .option-card h3 { font-size: 16px; margin-bottom: 8px; }
    .option-card p { font-size: 13px; color: #888; }
    .option-card:hover { border-color: var(--primary-mint); transform: translateY(-5px); box-shadow: 0 10px 20px rgba(46, 196, 182, 0.1); }
    .option-card.selected { border-color: var(--primary-mint); background: rgba(46, 196, 182, 0.05); }
    .upload-area { border: 2px dashed var(--primary-mint); border-radius: 20px; padding: 40px; text-align: center; background: rgba(46, 196, 182, 0.02); cursor: pointer; transition: 0.3s; }
    .upload-area:hover { background: rgba(46, 196, 182, 0.05); }
    .upload-area i { font-size: 50px; color: var(--primary-mint); margin-bottom: 15px; }
    .quiz-footer { display: flex; justify-content: space-between; border-top: 1px solid #eee; padding-top: 30px; }
    .btn-nav { padding: 14px 35px; border-radius: 50px; font-weight: 700; text-transform: uppercase; cursor: pointer; transition: 0.3s; border: none; }
    .btn-prev { background: #eee; color: #666; }
    .btn-next { background: var(--primary-mint); color: white; box-shadow: 0 8px 20px rgba(46, 196, 182, 0.3); }
    .btn-next:hover { background: var(--dark-mint); transform: scale(1.05); }
</style>

<div class="ai-wrapper">
    <div class="ai-intro">
        <h1>Khám phá làn da của bạn</h1>
        <p>Chỉ với vài câu hỏi và một bức ảnh, AI của Velvy Skin sẽ phân tích tình trạng da và thiết kế quy trình chăm sóc dành riêng cho bạn.</p>
    </div>

    <form asp-action="AiResult" method="post" class="quiz-container" id="aiForm">
        <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>

        <input type="hidden" name="skinType" id="skinType" value="Da thường" />
        <input type="hidden" name="skinConcern" id="skinConcern" value="Mụn & Thâm" />

        <div class="step active" id="step1">
            <h2 class="step-title">Bạn cảm thấy làn da mình thuộc loại nào?</h2>
            <div class="options-grid">
                <div class="option-card" onclick="selectOption(this, 1, 'Da khô')">
                    <i class="fa-solid fa-droplet-slash"></i><h3>Da khô</h3><p>Căng, bong tróc</p>
                </div>
                <div class="option-card" onclick="selectOption(this, 1, 'Da dầu')">
                    <i class="fa-solid fa-droplet"></i><h3>Da dầu</h3><p>Nhiều bã nhờn</p>
                </div>
                <div class="option-card" onclick="selectOption(this, 1, 'Da hỗn hợp')">
                    <i class="fa-solid fa-water"></i><h3>Da hỗn hợp</h3><p>Dầu vùng chữ T</p>
                </div>
                <div class="option-card selected" onclick="selectOption(this, 1, 'Da thường')">
                    <i class="fa-solid fa-face-smile"></i><h3>Da thường</h3><p>Cân bằng</p>
                </div>
            </div>
        </div>

        <div class="step" id="step2">
            <h2 class="step-title">Vấn đề da bạn quan tâm nhất là gì?</h2>
            <div class="options-grid">
                <div class="option-card selected" onclick="selectOption(this, 2, 'Mụn & Thâm')">
                    <i class="fa-solid fa-virus"></i><h3>Mụn & Thâm</h3>
                </div>
                <div class="option-card" onclick="selectOption(this, 2, 'Sạm nám')">
                    <i class="fa-solid fa-sun"></i><h3>Sạm nám</h3>
                </div>
                <div class="option-card" onclick="selectOption(this, 2, 'Lão hóa')">
                    <i class="fa-solid fa-clock-rotate-left"></i><h3>Lão hóa</h3>
                </div>
                <div class="option-card" onclick="selectOption(this, 2, 'Nhạy cảm')">
                    <i class="fa-solid fa-hand-holding-medical"></i><h3>Nhạy cảm</h3>
                </div>
            </div>
        </div>

        <div class="step" id="step3">
            <h2 class="step-title">Tải ảnh khuôn mặt để AI phân tích</h2>
            <input type="file" id="ai-upload-input" accept="image/*" capture="user" style="display: none;">
            <div class="upload-area" id="drop-zone" onclick="document.getElementById('ai-upload-input').click()">
                <i class="fa-solid fa-camera-retro"></i>
                <h3 id="upload-status">Chụp ảnh hoặc Tải lên</h3>
                <img id="preview-img" style="display:none; max-width: 200px; margin: 20px auto; border-radius: 10px; border: 2px solid var(--primary-mint);">
            </div>
        </div>

        <div class="quiz-footer mt-4">
            <button type="button" class="btn-nav btn-prev" id="btnPrev" onclick="changeStep(-1)" style="visibility: hidden;">Quay lại</button>
            <button type="button" class="btn-nav btn-next" id="btnNext" onclick="changeStep(1)">Tiếp theo</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let currentStep = 1;
        const totalSteps = 3;

        // Bắt dữ liệu khi click
        function selectOption(el, stepNumber, value) {
            const allOptions = el.parentElement.querySelectorAll('.option-card');
            allOptions.forEach(opt => opt.classList.remove('selected'));
            el.classList.add('selected');

            // Ghi dữ liệu vào ống hút ẩn
            if (stepNumber === 1) document.getElementById('skinType').value = value;
            if (stepNumber === 2) document.getElementById('skinConcern').value = value;
        }

        function changeStep(n) {
            const steps = document.querySelectorAll('.step');
            if (n === 1 && currentStep === totalSteps) { startAnalysis(); return; }

            steps[currentStep - 1].classList.remove('active');
            currentStep += n;
            if (currentStep < 1) currentStep = 1;
            if (currentStep > totalSteps) currentStep = totalSteps;
            steps[currentStep - 1].classList.add('active');

            const progress = (currentStep / totalSteps) * 100;
            document.getElementById('progressFill').style.width = progress + "%";
            document.getElementById('btnPrev').style.visibility = (currentStep === 1) ? 'hidden' : 'visible';
            document.getElementById('btnNext').innerText = (currentStep === totalSteps) ? 'Phân tích da' : 'Tiếp theo';
        }

        document.getElementById('ai-upload-input').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    const img = document.getElementById('preview-img');
                    img.src = event.target.result;
                    img.style.display = 'block';
                    document.querySelector('.upload-area i').style.display = 'none';
                    document.getElementById('upload-status').innerText = "Ảnh đã sẵn sàng!";
                }
                reader.readAsDataURL(file);
            }
        });

        function startAnalysis() {
            const fileInput = document.getElementById('ai-upload-input');
            if (!fileInput.files[0]) {
                alert("Vui lòng chụp ảnh hoặc tải ảnh lên để AI phân tích!"); return;
            }
            document.getElementById('upload-status').innerText = "AI đang quét...";
            const btnNext = document.getElementById('btnNext');
            btnNext.disabled = true;
            btnNext.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang xử lý...';
            
            // Chờ 2.5s lấy le với khách hàng rồi GỬI FORM VỀ C#
            setTimeout(() => { document.getElementById('aiForm').submit(); }, 2500);
        }
    </script>
}