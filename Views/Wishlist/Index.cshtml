@model List<VelvySkinWeb.Models.Product>
@{
    ViewData["Title"] = "Yêu Thích";
}

<style>
    .container { padding: 30px 5%; max-width: 1400px; margin: 0 auto; min-height: 50vh; font-family: 'Montserrat', sans-serif;}
    .page-title { font-family: 'Playfair Display', serif; font-size: 32px; margin-bottom: 10px; color: #222; }
    .wishlist-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; padding-bottom: 15px; border-bottom: 1px solid #eee; }
    .wishlist-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px; }
    
    .product-card { background: white; border-radius: 15px; padding: 15px; border: 1px solid #f0f0f0; transition: 0.3s; position: relative; overflow: hidden; }
    .product-card:hover { transform: translateY(-10px); box-shadow: 0 15px 30px rgba(0,0,0,0.08); border-color: var(--primary-mint); }

    .remove-wish { position: absolute; top: 25px; right: 25px; z-index: 10; background: white; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: none; cursor: pointer; box-shadow: 0 4px 8px rgba(0,0,0,0.1); transition: 0.3s; color: #ff4d4d; }
    .remove-wish:hover { transform: scale(1.1); background: #ffebee; }

    .img-container { width: 100%; height: 280px; overflow: hidden; border-radius: 10px; margin-bottom: 15px; background: #f9f9f9; display: flex; align-items: center; justify-content: center;}
    .product-img { max-width: 100%; max-height: 100%; object-fit: contain; transition: 0.5s; }
    .product-card:hover .product-img { transform: scale(1.08); }

    .product-info h3 { font-size: 11px; color: #999; text-transform: uppercase; margin-bottom: 5px; }
    .product-info h2 { font-size: 16px; color: #333; margin-bottom: 10px; height: 45px; overflow: hidden; line-height: 1.4; font-weight: 600; }
    .price { font-size: 18px; font-weight: 700; color: var(--primary-mint); margin-bottom: 20px; }

    .product-buttons { display: flex; gap: 10px; }
    .btn-detail { flex: 1; padding: 12px; background: #f5f5f5; color: #555; text-decoration: none; text-align: center; border-radius: 8px; font-weight: 600; font-size: 14px; transition: 0.3s; }
    .btn-detail:hover { background: #e0e0e0; color: #000; }
    .btn-add-cart { flex: 2; padding: 12px; background: var(--dark-mint); color: white; border: none; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: 0.3s; text-align: center;}
    .btn-add-cart:hover { background: var(--primary-mint); box-shadow: 0 5px 15px rgba(46,196,182,0.3); color: white;}

    .empty-wishlist { text-align: center; padding: 50px 0; color: #777; }
    .empty-wishlist i { font-size: 60px; color: var(--accent-pink); margin-bottom: 20px; }
    .empty-wishlist p { font-size: 18px; margin-bottom: 20px; }
    .empty-wishlist a { background: var(--primary-mint); color: white; padding: 12px 30px; border-radius: 30px; text-decoration: none; font-weight: 600; display: inline-block; transition: 0.3s; }
</style>

<div class="container">
    <div class="breadcrumb" style="margin-bottom: 20px; font-size: 14px; color: #888;">
        <a asp-controller="Home" asp-action="Index" style="color: var(--primary-mint); text-decoration: none;"><i class="fa-solid fa-house-chimney"></i> Trang chủ</a> 
        <span style="margin: 0 10px;">/</span> <span style="color: #444; font-weight: 600;">Yêu thích</span>
    </div>

    <h1 class="page-title">Danh Sách Yêu Thích</h1>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-wishlist">
            <i class="fa-regular fa-heart"></i>
            <p>Trái tim bạn đang trống vắng. Hãy lấp đầy nó bằng những món mỹ phẩm yêu thích nhé!</p>
            <a asp-controller="Home" asp-action="Index">Khám phá ngay</a>
        </div>
    }
    else
    {
        <p style="color:#777; margin-bottom: 25px;">Bạn có <strong>@Model.Count</strong> sản phẩm trong danh sách yêu thích.</p>

        <div class="wishlist-toolbar">
            <a asp-controller="Wishlist" asp-action="Clear" style="background: #ffebee; color: #ff4d4d; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; text-decoration: none; font-weight: 600; font-size: 14px;"><i class="fa fa-trash"></i> Xóa tất cả</a>
        </div>

        <div class="wishlist-grid">
            @foreach(var item in Model)
            {
                <div class="product-card">
                    <form asp-controller="Wishlist" asp-action="Toggle" method="post">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="remove-wish" title="Bỏ yêu thích">
                            <i class="fa fa-trash"></i>
                        </button>
                    </form>

                    <div class="img-container">
                        <img src="@item.ImageUrl" class="product-img" onerror="this.src='https://via.placeholder.com/500'">
                    </div>
                    <div class="product-info">
                        <h3>Velvy Exclusive</h3>
                        <h2>@item.Name</h2>
                        <p class="price">@item.Price.ToString("N0")đ</p>
                        
                        <div class="product-buttons">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="btn-detail">Chi tiết</a>
                            
                            <form asp-controller="Cart" asp-action="AddToCart" method="post" style="flex: 2;">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn-add-cart" style="width: 100%;">Thêm giỏ hàng</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>