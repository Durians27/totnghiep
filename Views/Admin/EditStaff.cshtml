@model VelvySkinWeb.Models.ViewModels.EditStaffViewModel
@{
    ViewData["Title"] = "Hồ sơ Nhân viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; 
    

    string avatarPath = $"/images/avatars/{@Model.Id}.jpg";
    string absolutePath = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "images", "avatars", $"{Model.Id}.jpg");
    bool hasAvatar = System.IO.File.Exists(absolutePath);
    string displayImage = hasAvatar ? avatarPath + "?v=" + DateTime.Now.Ticks : "https://ui-avatars.com/api/?name=" + Model.FullName + "&background=2ec4b6&color=fff&size=150";
}

<div style="padding: 30px; font-family: 'Montserrat', sans-serif; max-width: 900px; margin: 0 auto;">
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <h2 style="font-family: 'Playfair Display', serif; color: var(--dark-mint); font-weight: 700; margin: 0;">
            <i class="fa-solid fa-address-card"></i> HỒ SƠ NHÂN VIÊN
        </h2>
    </div>

    <div style="background: white; border-radius: 20px; padding: 40px; box-shadow: 0 10px 40px rgba(0,0,0,0.08);">
        <form asp-action="EditStaff" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            
            <div style="text-align: center; margin-bottom: 35px;">
                <label for="AvatarFile" style="cursor: pointer; position: relative; display: inline-block;">
                    <img id="avatarPreview" src="@displayImage" style="width: 140px; height: 140px; border-radius: 50%; object-fit: cover; border: 4px solid var(--light-mint); box-shadow: 0 8px 20px rgba(0,0,0,0.12); transition: 0.3s;" />
                    <div style="position: absolute; bottom: 5px; right: 5px; background: var(--primary-mint); color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 3px solid white; box-shadow: 0 3px 8px rgba(0,0,0,0.2);">
                        <i class="fa-solid fa-camera"></i>
                    </div>
                </label>
                <input type="file" asp-for="AvatarFile" id="AvatarFile" accept="image/*" style="display: none;" onchange="previewImage(event)" />
                <div style="font-size: 13px; color: #888; margin-top: 12px; font-weight: 500;">Nhấn vào ảnh để cập nhật diện mạo</div>
            </div>

            <h5 style="color: var(--primary-mint); font-weight: 700; font-size: 15px; margin-bottom: 20px; border-bottom: 2px solid #f1f1f1; padding-bottom: 10px;"><i class="fa-solid fa-user me-2"></i> THÔNG TIN CÁ NHÂN</h5>
            
            <div style="margin-bottom: 25px;">
                <label style="font-weight: 600; color: #555; font-size: 13px; text-transform: uppercase; margin-bottom: 8px; display: block;">Email (Tài khoản đăng nhập)</label>
                <input asp-for="Email" class="form-control" style="background: #f8f9fa; border-radius: 10px; padding: 14px; pointer-events: none; color: #6c757d; font-weight: 500;" readonly />
            </div>

            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 25px; margin-bottom: 25px;">
                <div>
                    <label style="font-weight: 600; color: #555; font-size: 13px; text-transform: uppercase; margin-bottom: 8px; display: block;">Họ và Tên <span style="color: red;">*</span></label>
                    <input asp-for="FullName" class="form-control" style="border-radius: 10px; padding: 14px;" required />
                    <span asp-validation-for="FullName" class="text-danger" style="font-size: 12px;"></span>
                </div>
                <div>
                    <label style="font-weight: 600; color: #555; font-size: 13px; text-transform: uppercase; margin-bottom: 8px; display: block;">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" style="border-radius: 10px; padding: 14px;" />
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px; margin-bottom: 25px;">
                <div>
                    <label style="font-weight: 600; color: #555; font-size: 13px; text-transform: uppercase; margin-bottom: 8px; display: block;">Ngày sinh</label>
                    <input asp-for="DateOfBirth" type="date" class="form-control" style="border-radius: 10px; padding: 14px;" />
                </div>
                <div>
                    <label style="font-weight: 600; color: #555; font-size: 13px; text-transform: uppercase; margin-bottom: 8px; display: block;">Giới tính</label>
                    <select asp-for="Gender" class="form-control" style="border-radius: 10px; padding: 14px;">
                        <option value="">-- Chưa cập nhật --</option>
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>
            </div>

            <div style="margin-bottom: 40px;">
                <label style="font-weight: 600; color: #555; font-size: 13px; text-transform: uppercase; margin-bottom: 8px; display: block;">Địa chỉ thường trú</label>
                <input asp-for="Address" class="form-control" style="border-radius: 10px; padding: 14px;" />
            </div>

            <h5 style="color: var(--primary-mint); font-weight: 700; font-size: 15px; margin-bottom: 20px; border-bottom: 2px solid #f1f1f1; padding-bottom: 10px;"><i class="fa-solid fa-briefcase me-2"></i> CÔNG VIỆC & GHI CHÚ NỘI BỘ</h5>
            
            <div style="margin-bottom: 25px;">
                <label style="font-weight: 600; color: #555; font-size: 13px; text-transform: uppercase; margin-bottom: 8px; display: block;">Vị trí phụ trách (Duty)</label>
                <select asp-for="PrimaryDuty" class="form-control" style="border-radius: 10px; padding: 14px; border: 2px solid var(--light-mint);">
                    <option value="Chuyên viên CSKH">Chuyên viên CSKH (Hỗ trợ, Rep ticket)</option>
                    <option value="Quản lý Kho">Quản lý Kho (Thêm/Sửa sản phẩm)</option>
                    <option value="Điều phối viên">Điều phối viên (Xử lý đơn hàng)</option>
                </select>
            </div>

            <div style="margin-bottom: 40px;">
                <label style="font-weight: 600; color: #d32f2f; font-size: 13px; text-transform: uppercase; margin-bottom: 8px; display: block;">
                    <i class="fa-solid fa-user-secret"></i> Ghi chú nội bộ (Chỉ cấp quản lý thấy)
                </label>
                <textarea asp-for="InternalNotes" class="form-control" rows="4" placeholder="Nhập đánh giá thái độ, ghi chú bảo lưu, kỷ luật..." style="border-radius: 10px; padding: 15px; background: #fffaf0; border: 1px solid #ffd8a8; font-size: 14px; resize: vertical;"></textarea>
            </div>

            <div style="display: flex; gap: 15px; justify-content: flex-end; border-top: 1px solid #eee; padding-top: 30px;">
                <a asp-action="Staffs" class="btn" style="background: #f1f1f1; color: #555; border-radius: 10px; padding: 12px 30px; font-weight: 600; text-decoration: none; transition: 0.3s;" onmouseover="this.style.background='#e2e6ea'" onmouseout="this.style.background='#f1f1f1'">Quay lại</a>
                <button type="submit" class="btn" style="background: var(--primary-mint, #2ec4b6); color: white; border-radius: 10px; padding: 12px 35px; font-weight: 600; border: none; box-shadow: 0 6px 15px rgba(46, 196, 182, 0.3); transition: 0.3s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                    <i class="fa-solid fa-floppy-disk me-2"></i> Lưu Cập Nhật
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>

        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function(){
                var output = document.getElementById('avatarPreview');
                output.src = reader.result;
            };
            if(event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }
    </script>
}