@model VelvySkinWeb.Models.UserProfile
@{
    ViewData["Title"] = "Hồ Sơ Quản Trị";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .admin-profile-wrapper {
        --primary-mint: #2ec4b6; --dark-mint: #208b81; --light-mint: #f0fdfa; --bg-gray: #f8f9fa; --gold: #c5a059;
        font-family: 'Montserrat', sans-serif; color: #333; padding: 20px; box-sizing: border-box; max-width: 1000px; margin: 0 auto;
    }
    
    .admin-profile-wrapper .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .admin-profile-wrapper .page-title { font-family: 'Playfair Display', serif; font-size: 28px; color: var(--dark-mint); margin: 0; font-weight: 700;}

    .admin-profile-wrapper .profile-container { display: grid; grid-template-columns: 320px 1fr; gap: 30px; }
    
    .admin-profile-wrapper .profile-sidebar { background: white; border-radius: 30px; padding: 40px 20px; text-align: center; box-shadow: 0 10px 40px rgba(0,0,0,0.03); border: 1px solid #f1f1f1; height: fit-content;}

    .admin-profile-wrapper .avatar-wrapper { position: relative; width: 130px; height: 130px; margin: 0 auto 20px; cursor: pointer; transition: 0.3s;}
    .admin-profile-wrapper .avatar-wrapper:hover { transform: scale(1.05); }
    .admin-profile-wrapper .avatar-img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 4px solid var(--light-mint); }
    .admin-profile-wrapper .upload-icon { position: absolute; bottom: 5px; right: 5px; width: 32px; height: 32px; background: var(--primary-mint); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 3px solid white; font-size: 14px; }

    .admin-profile-wrapper .admin-name { font-family: 'Playfair Display', serif; font-size: 22px; margin: 10px 0 5px; color: #222; font-weight: 700;}
    .admin-profile-wrapper .admin-role { font-size: 12px; font-weight: 700; color: var(--primary-mint); text-transform: uppercase; letter-spacing: 1px; }

    .admin-profile-wrapper .profile-details { background: white; border-radius: 30px; padding: 40px; box-shadow: 0 10px 40px rgba(0,0,0,0.03); border: 1px solid #f1f1f1; }
    .admin-profile-wrapper .section-title { font-size: 16px; font-weight: 700; margin-bottom: 25px; color: #444; border-bottom: 1px solid #f9f9f9; padding-bottom: 15px; }

    .admin-profile-wrapper .form-group { margin-bottom: 22px; }
    .admin-profile-wrapper label { display: block; font-size: 11px; font-weight: 700; color: #aaa; text-transform: uppercase; margin-bottom: 8px; }
    
    .admin-profile-wrapper input { width: 100%; padding: 15px 18px; border-radius: 12px; border: 1px solid transparent; background: #f9f9f9; font-family: inherit; font-size: 14px; color: #666; outline: none; transition: 0.3s; box-sizing: border-box; }

    /* Editing Mode */
    .admin-profile-wrapper .editing-mode input.editable { background: white; border-color: #eee; color: #222; }
    .admin-profile-wrapper .editing-mode input.editable:focus { border-color: var(--primary-mint); box-shadow: 0 0 0 4px var(--light-mint); }

    /* Buttons */
    .admin-profile-wrapper .btn-group { display: flex; gap: 10px; }
    .admin-profile-wrapper .btn { padding: 12px 24px; border-radius: 12px; font-weight: 700; font-size: 13px; cursor: pointer; border: none; transition: 0.3s; font-family: inherit;}
    .admin-profile-wrapper .btn-edit { background: var(--light-mint); color: var(--primary-mint); }
    .admin-profile-wrapper .btn-save { background: var(--primary-mint); color: white; display: none; }
    .admin-profile-wrapper .btn-cancel { background: #f5f5f5; color: #888; display: none; }

    @@media (max-width: 768px) { .admin-profile-wrapper .profile-container { grid-template-columns: 1fr; } }
</style>

<div class="admin-profile-wrapper">
    <form id="profileForm" asp-controller="Admin" asp-action="AdminProfile" method="post" enctype="multipart/form-data">
        <div class="page-header">
            <h1 class="page-title">Hồ Sơ Quản Trị</h1>
            <div class="btn-group">
                <button type="button" class="btn btn-edit" id="editBtn" onclick="enableEdit()">
                    <i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa hồ sơ
                </button>
                <button type="button" class="btn btn-cancel" id="cancelBtn" onclick="disableEdit()">Hủy</button>
                <button type="submit" class="btn btn-save" id="saveBtn">Cập nhật ngay</button>
            </div>
        </div>

        <div class="profile-container">
            <div class="profile-sidebar">
                <label for="avatarUpload" class="avatar-wrapper" title="Nhấn để đổi ảnh đại diện">
                    <img src="~/images/avatars/@(Model.UserId).jpg" id="avatarPreview" class="avatar-img" onerror="this.src='https://i.pravatar.cc/300?u=@ViewBag.UserEmail'" alt="Admin">
                    <div class="upload-icon"><i class="fa-solid fa-camera"></i></div>
                </label>
                <input type="file" id="avatarUpload" name="avatarFile" hidden accept="image/*" onchange="previewImage(event)" disabled>

                <h2 class="admin-name">@(string.IsNullOrEmpty(Model.FullName) ? "Admin Velvy" : Model.FullName)</h2>
                <span class="admin-role">@ViewBag.Role</span>

                <div style="margin-top: 15px; font-size: 13px; font-weight: 700; color: var(--gold); letter-spacing: 1px;">
                    ID: #@Model.UserId.Substring(0, 8).ToUpper()
                </div>

                <div style="margin-top: 30px; background: #fffcf0; border: 1px solid #fdf2ce; padding: 15px; border-radius: 15px; color: #856404; font-size: 12px; font-weight: 600;">
                    <i class="fa-solid fa-shield-halved"></i> Tài khoản của bạn được bảo vệ bởi hệ thống an ninh Velvy Skin.
                </div>
            </div>

            <div class="profile-details">
                <div class="section-title">Thông Tin Cá Nhân</div>
                
                <div class="form-group">
    <label>Họ và Tên (Không thể đổi)</label>
    <input asp-for="FullName" type="text" readonly title="Vui lòng liên hệ Admin nếu bạn đổi tên">
</div>

                <div class="form-group">
                    <label>Số điện thoại</label>
                    <input asp-for="PhoneNumber" type="tel" class="editable" readonly>
                </div>

                <div class="form-group">
                    <label>Email đăng nhập (Không thể đổi)</label>
                    <input type="email" value="@ViewBag.UserEmail" readonly title="Liên hệ Super Admin nếu muốn đổi Email">
                </div>

                <div class="section-title" style="margin-top: 40px;">Bảo Mật & Phân Quyền</div>
                
                <div class="form-group">
                    <label>Cấp độ truy cập</label>
                    <input type="text" value="@ViewBag.Role" readonly style="color: var(--gold); font-weight: 700;">
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const form = document.getElementById('profileForm');
        const editBtn = document.getElementById('editBtn');
        const saveBtn = document.getElementById('saveBtn');
        const cancelBtn = document.getElementById('cancelBtn');
        const editableInputs = document.querySelectorAll('.editable');
        const avatarInput = document.getElementById('avatarUpload');


        function enableEdit() {
            form.classList.add('editing-mode');
            editableInputs.forEach(input => input.removeAttribute('readonly'));
            avatarInput.removeAttribute('disabled');
            
            editBtn.style.display = 'none';
            saveBtn.style.display = 'block';
            cancelBtn.style.display = 'block';
        }


        function disableEdit() {
            form.classList.remove('editing-mode');
            editableInputs.forEach(input => input.setAttribute('readonly', true));
            avatarInput.setAttribute('disabled', true);
            
            editBtn.style.display = 'block';
            saveBtn.style.display = 'none';
            cancelBtn.style.display = 'none';

            window.location.reload(); 
        }


        function previewImage(event) {
            const reader = new FileReader();
            reader.onload = function() {
                const output = document.getElementById('avatarPreview');
                output.src = reader.result;
            };
            if(event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);

                enableEdit(); 
            }
        }


        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                Swal.fire({
                    title: "Thành công!",
                    text: "@Html.Raw(TempData["SuccessMsg"])",
                    icon: "success",
                    confirmButtonColor: "#2ec4b6"
                });
            </text>
        }
    </script>
}