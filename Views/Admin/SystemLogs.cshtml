@model IEnumerable<VelvySkinWeb.Models.AuditLog>
@{
    ViewData["Title"] = "Nhật ký hệ thống";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="padding: 30px; font-family: 'Montserrat', sans-serif;">
    <h2 style="font-family: 'Playfair Display', serif; color: var(--dark-mint); font-weight: 700; margin-bottom: 25px;">
        <i class="fa-solid fa-shield-halved"></i> NHẬT KÝ HỆ THỐNG 
    </h2>

    <div style="background: white; border-radius: 20px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
        <table class="table" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="border-bottom: 2px solid var(--primary-mint); text-align: left; font-size: 13px; color: #888;">
                    <th style="padding: 15px;">THỜI GIAN</th>
                    <th style="padding: 15px;">NGƯỜI THỰC HIỆN</th>
                    <th style="padding: 15px;">HÀNH ĐỘNG</th>
                    <th style="padding: 15px;">CHI TIẾT THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr style="border-bottom: 1px solid #f5f5f5; font-size: 14px;">
                        <td style="padding: 15px; color: #666; width: 180px;">@log.Timestamp.ToString("HH:mm - dd/MM/yyyy")</td>
                        <td style="padding: 15px; font-weight: 600; color: var(--dark-mint);">@log.Username</td>
                        <td style="padding: 15px; width: 120px;">
                            @{
                                string badgeColor = "#f5f5f5";
                                string textColor = "#333";
                                if (log.ActionType == "UPDATE") { badgeColor = "#e1f5fe"; textColor = "#0288d1"; }
                                else if (log.ActionType == "CREATE") { badgeColor = "#e8f5e9"; textColor = "#2e7d32"; }
                                else if (log.ActionType == "DELETE") { badgeColor = "#ffebee"; textColor = "#c62828"; }
                                if (log.ActionType.Contains("SUCCESS")) { badgeColor = "#e8f5e9"; textColor = "#2e7d32"; } 
                                else if (log.ActionType.Contains("FAILED") || log.ActionType.Contains("ALERT")) { badgeColor = "#ffebee"; textColor = "#c62828"; } 
                                else if (log.ActionType.Contains("ORDER")) { badgeColor = "#fff3e0"; textColor = "#ef6c00"; } 
                            }
                            <span style="background: @badgeColor; color: @textColor; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 700;">
                                @log.ActionType
                            </span>
                        </td>
                        <td style="padding: 15px; line-height: 1.5;">@log.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>