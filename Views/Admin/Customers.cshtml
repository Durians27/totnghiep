@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Quản Lý Khách Hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --primary-mint: #2ec4b6; --dark-mint: #208b81; --light-mint: #f0fdfa; --bg-gray: #f8f9fa; --gold-vip: #d4a017;
    }
    
    .customer-wrapper { 
        font-family: 'Montserrat', sans-serif; 
        padding: 20px;
        box-sizing: border-box;
    }
    
    .customer-wrapper .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .customer-wrapper .page-title { font-family: 'Playfair Display', serif; font-size: 28px; color: var(--dark-mint); margin: 0; font-weight: 700;}

    .customer-wrapper .customer-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px; }
    .customer-wrapper .stat-card { background: white; padding: 20px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); display: flex; flex-direction: column; gap: 5px; }
    .customer-wrapper .stat-value { font-size: 24px; font-weight: 700; color: var(--dark-mint); }
    .customer-wrapper .stat-label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;}

    .customer-wrapper .toolbar { display: flex; gap: 15px; margin-bottom: 25px; align-items: center; }
    .customer-wrapper .search-box { flex: 1; position: relative; }
    .customer-wrapper .search-box input { width: 100%; padding: 12px 20px 12px 45px; border-radius: 15px; border: 1px solid #eee; outline: none; font-family: inherit; box-sizing: border-box; transition: 0.3s;}
    .customer-wrapper .search-box input:focus { border-color: var(--primary-mint); box-shadow: 0 0 0 3px var(--light-mint); }
    .customer-wrapper .search-box i { position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #aaa; }
    
    .customer-wrapper .filter-select { padding: 12px 20px; border-radius: 15px; border: 1px solid #eee; background: white; outline: none; font-family: inherit; color: #555; cursor: pointer; transition: 0.3s; font-size: 14px; font-weight: 500;}
    .customer-wrapper .filter-select:hover { border-color: var(--primary-mint); }

    .customer-wrapper .card { background: white; border-radius: 25px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); border: 1px solid #f1f1f1; overflow-x: auto;}
    .customer-wrapper table { width: 100%; border-collapse: collapse; min-width: 900px;}
    .customer-wrapper th { padding: 15px; color: var(--dark-mint); font-size: 12px; text-transform: uppercase; border-bottom: 2px solid var(--light-mint); }
    .customer-wrapper td { padding: 18px 15px; border-bottom: 1px solid #f9f9f9; font-size: 14px; vertical-align: middle;}

    .customer-wrapper .user-cell { display: flex; align-items: center; gap: 12px; }
    .customer-wrapper .user-avatar { width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 2px solid var(--light-mint); }
    
    .customer-wrapper .rank-badge { padding: 6px 15px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; display: inline-block; text-align: center; min-width: 80px;}
    .customer-wrapper .rank-vip { background: #fff9e6; color: var(--gold-vip); border: 1px solid #fdeeb3; } 
    .customer-wrapper .rank-member { background: #f0fdfa; color: var(--primary-mint); border: 1px solid #e0f9f6; } 
    .customer-wrapper .rank-new { background: #f5f5f5; color: #888; border: 1px solid #eee; } 

    .customer-wrapper .btn-detail { background: white; border: 1px solid #eee; padding: 8px 15px; border-radius: 10px; font-size: 12px; font-weight: 600; color: var(--dark-mint); cursor: pointer; transition: 0.3s; text-decoration: none;}
    .customer-wrapper .btn-detail:hover { background: var(--primary-mint); color: white; border-color: var(--primary-mint); }

    @@media (max-width: 992px) { 
        .customer-wrapper .customer-stats { grid-template-columns: 1fr 1fr; } 
        .customer-wrapper .toolbar { flex-wrap: wrap; } 
    }
</style>

<div class="customer-wrapper">
    <div class="page-header">
        <h1 class="page-title">Cộng Đồng Velvy Skin</h1>
        
       <a asp-controller="Admin" asp-action="CreateCustomer" class="btn-detail" style="background: var(--primary-mint); color: white; border: none; padding: 12px 25px; border-radius: 15px; font-size: 14px; text-decoration: none; display: inline-block;">
            <i class="fa-solid fa-user-plus"></i> Thêm khách hàng
        </a>
    </div>

    <div class="customer-stats">
        <div class="stat-card">
            <span class="stat-label">Tổng khách hàng</span>
            <span class="stat-value">@ViewBag.TotalCustomers</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Thành viên từ Vàng trở lên</span>
            <span class="stat-value" style="color: var(--gold-vip);">@ViewBag.TotalVIPs</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Khách mới tháng này</span>
            <span class="stat-value">+@ViewBag.NewThisMonth</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Tỉ lệ quay lại (Giả định)</span>
            <span class="stat-value">68%</span>
        </div>
    </div>

    <form asp-controller="Admin" asp-action="Customers" method="get" class="toolbar">
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" name="search" value="@ViewBag.SearchTerm" placeholder="Tìm tên khách hàng, số điện thoại hoặc email..." onchange="this.form.submit()">
        </div>
        
        <select class="filter-select">
            <option>Tất cả phân hạng</option>
            <option>Kim Cương</option>
            <option>Vàng</option>
            <option>Bạc</option>
            <option>Member</option>
        </select>
        
    </form>

    <div class="card">
        <table>
            <thead>
                <tr>
                    <th style="width: 25%; text-align: left;">Khách hàng</th>
                    <th style="width: 15%; text-align: center;">Phân hạng</th>
                    <th style="width: 15%; text-align: center;">Tổng chi tiêu</th>
                    <th style="width: 10%; text-align: center;">Đơn hàng</th>
                    <th style="width: 10%; text-align: center;">Hoạt động cuối</th>
                    <th style="width: 10%; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var customer in Model)
                    {
                        <tr>
                            <td style="text-align: left;">
                                <div class="user-cell">
                                    <img class="user-avatar" src="/images/avatars/@(customer.UserId).jpg" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@(customer.FullName)&background=c5a059&color=fff';" alt="Avatar">
                                    <div>
                                        <div style="font-weight: 700; color: #222;">@customer.FullName</div>
                                        <div style="font-size: 11px; color: #888; margin-top: 3px;">@customer.Phone</div>
                                    </div>
                                </div>
                            </td>
                            <td style="text-align: center;">
                                <span class="rank-badge @customer.BadgeClass">@customer.Rank</span>
                            </td>
                            <td style="text-align: center; font-weight: 600; color: #444;">@customer.TotalSpent.ToString("N0")đ</td>
                            <td style="text-align: center;"><span style="background: #f1f1f1; padding: 4px 10px; border-radius: 8px; font-size: 12px; font-weight: 600;">@customer.OrderCount đơn</span></td>
                            <td style="text-align: center; color: #888; font-size: 12px;">@customer.LastActive</td>
                            <td style="text-align: center;">
                                <a asp-controller="Admin" asp-action="CustomerDetail" asp-route-id="@customer.UserId" class="btn-detail">Hồ sơ</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align: center; color: #888; padding: 40px;">
                            <i class="fa-solid fa-users-slash" style="font-size: 40px; color: #ddd; margin-bottom: 15px;"></i><br>
                            Không tìm thấy khách hàng nào phù hợp.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>