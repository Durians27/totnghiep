@model VelvySkinWeb.Models.SupportTicket
@{
    ViewData["Title"] = "Chat Theo Đơn Hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .order-chat-wrapper {
        --primary-mint: #2ec4b6; --dark-mint: #208b81; --light-mint: #f0fdfa;
        --bg-gray: #f8f9fa; --blue-ship: #3498db; --orange-warn: #f39c12;
        font-family: 'Montserrat', sans-serif; color: #333;
    }
    
    .order-chat-wrapper .main-content { padding: 30px; max-width: 1200px; margin: 0 auto; }
    .order-chat-wrapper .grid-layout { display: grid; grid-template-columns: 350px 1fr; gap: 20px; height: calc(100vh - 120px); min-height: 600px; }

    .order-chat-wrapper .card { background: white; border-radius: 25px; padding: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); border: 1px solid #f1f1f1; display: flex; flex-direction: column; }
    
    .order-chat-wrapper .order-summary { margin-bottom: 20px; text-align: center; }
    .order-chat-wrapper .order-id { font-family: 'Playfair Display', serif; font-size: 22px; color: var(--dark-mint); margin: 10px 0; }
    
    .order-chat-wrapper .status-pill { display: inline-block; padding: 6px 15px; border-radius: 20px; font-size: 11px; font-weight: 700; background: #e1f0ff; color: var(--blue-ship); text-transform: uppercase; }

    .order-chat-wrapper .tracking-mini { margin-top: 25px; position: relative; padding-left: 30px; text-align: left; }
    .order-chat-wrapper .step { position: relative; padding-bottom: 20px; font-size: 12px; color: #aaa; }
    .order-chat-wrapper .step.active { color: #333; font-weight: 600; }
    .order-chat-wrapper .step::before { content: ''; position: absolute; left: -21px; top: 3px; width: 10px; height: 10px; border-radius: 50%; background: #ddd; }
    .order-chat-wrapper .step.active::before { background: var(--blue-ship); box-shadow: 0 0 0 4px #e1f0ff; }
    .order-chat-wrapper .step:not(:last-child)::after { content: ''; position: absolute; left: -17px; top: 15px; width: 2px; height: 100%; background: #eee; }

    .order-chat-wrapper .chat-header { border-bottom: 1px solid #f5f5f5; padding-bottom: 15px; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center; }
    .order-chat-wrapper .chat-messages { flex: 1; overflow-y: auto; padding-right: 10px; display: flex; flex-direction: column; gap: 15px; }
    
    .order-chat-wrapper .msg { max-width: 70%; padding: 12px 18px; border-radius: 18px; font-size: 14px; line-height: 1.5; }
    .order-chat-wrapper .msg.bot { align-self: flex-start; background: #f1f1f1; border-bottom-left-radius: 4px; }
    .order-chat-wrapper .msg.admin { align-self: flex-end; background: var(--primary-mint); color: white; border-bottom-right-radius: 4px; }
    .order-chat-wrapper .msg-time { font-size: 10px; margin-top: 5px; opacity: 0.6; display: block; }

    .order-chat-wrapper .quick-scripts { padding: 15px 0; border-top: 1px solid #eee; display: flex; gap: 10px; overflow-x: auto; scrollbar-width: none; }
    .order-chat-wrapper .quick-scripts::-webkit-scrollbar { display: none; }
    .order-chat-wrapper .script-btn { background: white; border: 1px solid var(--primary-mint); color: var(--primary-mint); padding: 8px 15px; border-radius: 10px; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; transition: 0.3s; }
    .order-chat-wrapper .script-btn:hover { background: var(--primary-mint); color: white; }

    .order-chat-wrapper .input-box { display: flex; gap: 10px; margin-top: 10px; }
    .order-chat-wrapper input[type="text"] { flex: 1; padding: 12px 20px; border-radius: 15px; border: 1px solid #eee; outline: none; transition: 0.3s; }
    .order-chat-wrapper input[type="text"]:focus { border-color: var(--primary-mint); }
</style>

<div class="order-chat-wrapper">
    <div class="main-content">
        <a asp-controller="Admin" asp-action="Support" style="display: inline-block; margin-bottom: 20px; color: #888; text-decoration: none; font-weight: 600; font-size: 13px;">
            <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
        </a>

        <div class="grid-layout">
            <div class="card">
                <div class="order-summary">
                    <div class="status-pill">@Model.Status</div>
                    <h2 class="order-id">@(string.IsNullOrEmpty(Model.OrderCode) ? "N/A" : Model.OrderCode)</h2>
                    <p style="font-size: 13px; color: #888;">Khách hàng: <strong>@Model.UserFullName</strong></p>
                    <p style="font-size: 12px; color: #aaa;">@Model.UserEmail</p>
                </div>

                <div class="tracking-mini">
                    <div class="step active"><i class="fa-solid fa-check"></i> Đã xác nhận đơn</div>
                    <div class="step active"><i class="fa-solid fa-check"></i> Đang xử lý hỗ trợ</div>
                    <div class="step">Hoàn tất xử lý</div>
                </div>

                <div style="margin-top: auto; padding-top: 20px; border-top: 1px solid #f5f5f5;">
                    <div style="font-size: 11px; color: #aaa; text-transform: uppercase; font-weight: 700; margin-bottom: 10px;">Phân loại yêu cầu</div>
                    <div style="font-size: 13px; color: var(--orange-warn); background: #fff9e6; padding: 10px; border-radius: 10px; font-weight: 600; text-align: center;">
                        <i class="fa-solid fa-truck-fast"></i> @Model.IssueType
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="chat-header">
                    <div>
                        <div style="font-weight: 700; color: var(--dark-mint);">Hỗ trợ đơn hàng</div>
                        <div style="font-size: 12px; color: #aaa;">Đang kết nối trực tiếp...</div>
                    </div>
                    <form asp-controller="Admin" asp-action="ResolveTicket" method="post" style="margin: 0;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" style="background: #fff5f5; border: 1px solid #ffebeb; padding: 8px 15px; border-radius: 10px; font-size: 12px; font-weight: 600; cursor: pointer; color: #ff4d4d; transition: 0.3s;" onmouseover="this.style.background='#ffebeb'">
                            <i class="fa-solid fa-check-double"></i> Đóng yêu cầu
                        </button>
                    </form>
                </div>

                <div class="chat-messages" id="chatBox">
                    @if (Model.TicketMessages != null && Model.TicketMessages.Any())
                    {
                        foreach (var msg in Model.TicketMessages.OrderBy(m => m.CreatedAt))
                        {
                            if (msg.Sender == "User")
                            {
                                <div class="msg bot">
                                    @msg.Content
                                    <span class="msg-time">@msg.CreatedAt.ToString("HH:mm - dd/MM")</span>
                                </div>
                            }
                            else if (msg.Sender == "Admin")
                            {
                                <div class="msg admin">
                                    @msg.Content
                                    <span class="msg-time" style="color: #cbf3f0;">@msg.CreatedAt.ToString("HH:mm - dd/MM")</span>
                                </div>
                            }
                            else if (msg.Sender == "System")
                            {
                                <div style="text-align: center; margin: 10px 0;">
                                    <span style="background: #fff3cd; color: #856404; padding: 5px 15px; border-radius: 20px; font-size: 11px; font-weight: 600;">
                                        @Html.Raw(msg.Content)
                                    </span>
                                </div>
                            }
                        }
                    }
                </div>

                @if (Model.Status != "Đã hoàn thành")
                {
                    <div class="quick-scripts">
                        <button class="script-btn" onclick="fillQuickMsg('🔔 Dạ bưu tá báo dự kiến chiều nay sẽ giao ạ. Không biết tầm 17h bạn có tiện nhận hàng không?')">Thông báo đang giao</button>
                        <button class="script-btn" onclick="fillQuickMsg('📍 Shop đã cập nhật ghi chú địa chỉ/SĐT mới cho đơn vị vận chuyển rồi ạ.')">Cập nhật địa chỉ</button>
                        <button class="script-btn" onclick="fillQuickMsg('⏳ Thật xin lỗi bạn vì sự chậm trễ này, do kho đang quá tải mùa sale ạ.')">Xin lỗi giao chậm</button>
                        <button class="script-btn" onclick="fillQuickMsg('📦 Khi nhận hàng bạn nhớ quay video đồng kiểm để shop tiện hỗ trợ nhé.')">Hướng dẫn đồng kiểm</button>
                    </div>

                    <form asp-controller="Admin" asp-action="ReplyTicket" method="post" class="input-box">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="text" id="chatInput" name="replyContent" placeholder="Nhập tin nhắn hỗ trợ vận chuyển..." autocomplete="off" required>
                        <button type="submit" style="background: var(--primary-mint); color: white; border: none; padding: 0 20px; border-radius: 12px; cursor: pointer; transition: 0.3s;" onmouseover="this.style.background='var(--dark-mint)'" onmouseout="this.style.background='var(--primary-mint)'">
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </form>
                }
                else
                {
                    <div style="text-align: center; color: #888; font-size: 13px; font-weight: 500; padding: 15px; background: #f9f9f9; border-radius: 15px; margin-top: 10px;">
                        <i class="fa-solid fa-lock"></i> Kênh hỗ trợ cho đơn hàng này đã đóng.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tự động cuộn xuống cuối hộp chat
        const chatBox = document.getElementById('chatBox');
        if(chatBox) chatBox.scrollTop = chatBox.scrollHeight;

        // Hàm điền tin nhắn nhanh vào ô Input
        function fillQuickMsg(text) {
            const input = document.getElementById('chatInput');
            if(input) {
                input.value = text;
                input.focus();
            }
        }
    </script>
}