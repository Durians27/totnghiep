@model VelvySkinWeb.Models.ViewModels.CreateStaffViewModel
@{
    ViewData["Title"] = "Tuyển Nhân Viên Mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="create-wrapper" style="max-width: 800px; margin: 40px auto; background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.08);">
    
    <div class="page-title" style="font-family: 'Playfair Display', serif; font-size: 24px; color: var(--dark-mint); margin-bottom: 30px; border-bottom: 2px solid var(--light-mint); padding-bottom: 15px; display: flex; align-items: center; gap: 12px;">
        <i class="fa-solid fa-user-plus"></i> Tuyển Dụng & Phân Công
    </div>

    @if (TempData["ErrorMsg"] != null)
    {
        <div style="background: #fff0f0; color: #d32f2f; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #d32f2f; font-weight: 500;">
            <i class="fa-solid fa-triangle-exclamation"></i> @TempData["ErrorMsg"]
        </div>
    }

    <form asp-action="CreateStaff" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 15px;"></div>

        <h5 style="color: var(--primary-mint); font-weight: 700; font-size: 15px; margin-bottom: 15px; border-bottom: 1px solid #eee; padding-bottom: 10px;"><i class="fa-solid fa-right-to-bracket me-2"></i> TÀI KHOẢN ĐĂNG NHẬP</h5>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; background: #f9f9f9; padding: 20px; border-radius: 12px;">
            <div>
                <label style="font-weight: 700; color: #555; font-size: 13px; margin-bottom: 8px; display: block;">Địa chỉ Email <span style="color: red;">*</span></label>
                <input asp-for="Email" placeholder="nhanvien@velvyskin.com" class="form-control" style="border-radius: 8px; padding: 12px;" required />
                <span asp-validation-for="Email" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div>
                <label style="font-weight: 700; color: #555; font-size: 13px; margin-bottom: 8px; display: block;">Mật khẩu khởi tạo <span style="color: red;">*</span></label>
                <input asp-for="Password" type="password" placeholder="Tối thiểu 6 ký tự" class="form-control" style="border-radius: 8px; padding: 12px;" required />
                <span asp-validation-for="Password" class="text-danger" style="font-size: 12px;"></span>
            </div>
        </div>

        <h5 style="color: var(--primary-mint); font-weight: 700; font-size: 15px; margin-bottom: 15px; border-bottom: 1px solid #eee; padding-bottom: 10px;"><i class="fa-solid fa-address-card me-2"></i> THÔNG TIN CÁ NHÂN</h5>
        <div style="margin-bottom: 20px;">
            <label style="font-weight: 700; color: #555; font-size: 13px; margin-bottom: 8px; display: block;">Họ và Tên <span style="color: red;">*</span></label>
            <input asp-for="FullName" placeholder="Nhập tên đầy đủ của nhân viên" class="form-control" style="border-radius: 8px; padding: 12px;" required />
            <span asp-validation-for="FullName" class="text-danger" style="font-size: 12px;"></span>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 20px;">
            <div>
                <label style="font-weight: 700; color: #555; font-size: 13px; margin-bottom: 8px; display: block;">Số điện thoại</label>
                <input asp-for="PhoneNumber" placeholder="0987..." class="form-control" style="border-radius: 8px; padding: 12px;" />
            </div>
            <div>
                <label style="font-weight: 700; color: #555; font-size: 13px; margin-bottom: 8px; display: block;">Ngày sinh</label>
                <input asp-for="DateOfBirth" type="date" class="form-control" style="border-radius: 8px; padding: 12px;" />
            </div>
            <div>
                <label style="font-weight: 700; color: #555; font-size: 13px; margin-bottom: 8px; display: block;">Giới tính</label>
                <select asp-for="Gender" class="form-control" style="border-radius: 8px; padding: 12px;">
                    <option value="">-- Chọn --</option>
                    <option value="Nam">Nam</option>
                    <option value="Nữ">Nữ</option>
                    <option value="Khác">Khác</option>
                </select>
            </div>
        </div>

        <div style="margin-bottom: 30px;">
            <label style="font-weight: 700; color: #555; font-size: 13px; margin-bottom: 8px; display: block;">Địa chỉ thường trú</label>
            <input asp-for="Address" placeholder="Số nhà, Đường, Phường, Quận, Thành phố..." class="form-control" style="border-radius: 8px; padding: 12px;" />
        </div>

        <h5 style="color: var(--primary-mint); font-weight: 700; font-size: 15px; margin-bottom: 15px; border-bottom: 1px solid #eee; padding-bottom: 10px;"><i class="fa-solid fa-briefcase me-2"></i> CÔNG VIỆC & NHẬN DIỆN</h5>
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 30px;">
            <div>
                <label style="font-weight: 700; color: #555; font-size: 13px; margin-bottom: 8px; display: block;">Vị trí phụ trách chính (Duty)</label>
                <select asp-for="PrimaryDuty" class="form-control" style="border-radius: 8px; padding: 12px; border: 2px solid var(--light-mint);">
                    <option value="Chuyên viên CSKH">Chuyên viên CSKH (Hỗ trợ, Rep ticket)</option>
                    <option value="Quản lý Kho">Quản lý Kho (Thêm/Sửa sản phẩm)</option>
                    <option value="Điều phối viên">Điều phối viên (Xử lý đơn hàng)</option>
                </select>
            </div>
            <div>
                <label style="font-weight: 700; color: #555; font-size: 13px; margin-bottom: 8px; display: block;">Tải lên Avatar (Tùy chọn)</label>
                <input type="file" asp-for="AvatarFile" accept="image/*" class="form-control" style="border-radius: 8px; padding: 9px;" />
            </div>
        </div>

        <div style="display: flex; gap: 15px; justify-content: flex-end; border-top: 1px solid #eee; padding-top: 25px;">
            <a asp-action="Staffs" class="btn" style="padding: 12px 25px; border-radius: 8px; background: #f1f1f1; color: #666; font-weight: 600; text-decoration: none;">Hủy bỏ</a>
            <button type="submit" class="btn" style="padding: 12px 30px; border-radius: 8px; background: var(--primary-mint, #2ec4b6); color: white; font-weight: 600; border: none; box-shadow: 0 4px 10px rgba(46, 196, 182, 0.3);">
                <i class="fa-solid fa-user-check me-1"></i> Khởi tạo tài khoản
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}